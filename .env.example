# ============================================
# LangGraph 教程项目 - 环境变量模板
# 复制为 .env 后填入你的实际配置
# ============================================

# --------------------------------------------------
# LLM 配置 (必填)
# --------------------------------------------------
# 你的 LLM API Key
OPENAI_API_KEY=sk-xxx

# API Base URL，默认 OpenAI 官方
# 如果使用 Azure、DashScope、OpenRouter 等，请修改此处
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 使用的模型名称
OPENAI_MODEL=deepseek-v4-flash

# --------------------------------------------------
# PostgreSQL 数据库配置
# --------------------------------------------------
POSTGRES_USER=langgraph
POSTGRES_PASSWORD=langgraph
POSTGRES_DB=langgraph

# --------------------------------------------------
# Redis 缓存配置
# --------------------------------------------------
REDIS_PASSWORD=redis

# --------------------------------------------------
# Langfuse 可观测性配置 (可选)
# --------------------------------------------------
# 首次启动 Langfuse 后，在界面创建项目获取 API Key
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=http://localhost:3000

# Langfuse 安全密钥 (首次启动前必须修改！)
# 生成命令: openssl rand -hex 32
LANGFUSE_ENCRYPTION_KEY=changeme_please_generate_with_openssl_rand_hex_32
LANGFUSE_SALT=changeme_salt
NEXTAUTH_SECRET=changeme_nextauth_secret

# MinIO 对象存储密码
MINIO_PASSWORD=miniosecret

# ClickHouse 密码
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse

# --------------------------------------------------
# 其他配置
# --------------------------------------------------
TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false
