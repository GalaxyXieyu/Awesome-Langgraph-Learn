  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 预构建 vs 自定义 Agent 深度对比\n",
    "\n",
    "在生产环境中，选择合适的 Agent 架构至关重要。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# 选型决策矩阵：预构建 Agent vs 自定义 StateGraph\n",
    "# 本 cell 用真实代码展示两种方案的核心差异\n",
    "# ============================================================\n",
    "\n",
    "from typing import TypedDict, Annotated\n",
    "\n",
    "# --- 方案 A：预构建 create_react_agent（模拟，展示概念）---\n",
    "def demo_prebuilt_agent():\n",
    "    \"\"\"\n",
    "    预构建 Agent 的核心特征：\n",
    "    - 开发速度极快，几行代码即可运行\n",
    "    - 内部状态黑盒，难以干预执行流程\n",
    "    - 仅支持工具调用路由，不支持条件分支\n",
    "    \"\"\"\n",
    "    # 伪代码示意（展示 API 结构，非真实运行）\n",
    "    code_example = '''\n",
    "    from langgraph.prebuilt import create_react_agent\n",
    "    \n",
    "    agent = create_react_agent(\n",
    "        model=chat_model,           # LLM 模型\n",
    "        tools=[search, calculator], # 工具列表\n",
    "        checkpointer=checkpointer   # 记忆后端\n",
    "    )\n",
    "    result = agent.invoke({\"messages\": [(\"human\", query)]})\n",
    "    '''\n",
    "    return code_example\n",
    "\n",
    "\n",
    "# --- 方案 B：自定义 StateGraph（真实可运行骨架）---\n",
    "class AgentState(TypedDict):\n",
    "    \"\"\"自定义状态定义——完全可控的数据结构\"\"\"\n",
    "    messages: List[Dict[str, Any]]\n",
    "    query: str\n",
    "    intent: Optional[str]\n",
    "    tool_calls: List[Dict[str, Any]]\n",
    "    final_answer: Optional[str]\n",
    "    metadata: Dict[str, Any]\n",
    "\n",
    "\n",
    "def intent_classifier_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"意图识别节点——可插入自定义逻辑、缓存、日志\"\"\"\n",
    "    query = state[\"query\"]\n",
    "    # 生产级：这里可以接入真实 LLM + 缓存 + 评分上报\n",
    "    intent = \"search\" if \"查\" in query or \"搜索\" in query else \"chat\"\n",
    "    state[\"intent\"] = intent\n",
    "    state[\"metadata\"][\"intent_node_ms\"] = 23\n",
    "    return state\n",
    "\n",
    "\n",
    "def route_by_intent(state: AgentState) -> str:\n",
    "    \"\"\"条件路由——任意复杂的业务逻辑分支\"\"\"\n",
    "    intent = state.get(\"intent\")\n",
    "    if intent == \"search\":\n",
    "        return \"search_node\"\n",
    "    return \"chat_node\"\n",
    "\n",
    "\n",
    "def search_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"搜索节点——可并行调用多个工具\"\"\"\n",
    "    state[\"tool_calls\"] = [{\"tool\": \"web_search\", \"query\": state[\"query\"]}]\n",
    "    state[\"metadata\"][\"search_node_ms\"] = 312\n",
    "    return state\n",
    "\n",
    "\n",
    "def chat_node(state: AgentState) -> AgentState:\n",
    "    \"\"\"聊天节点——直接生成回复\"\"\"\n",
    "    state[\"final_answer\"] = f\"这是对 '{state['query']}' 的聊天回复\"\n",
    "    state[\"metadata\"][\"chat_node_ms\"] = 150\n",
    "    return state\n",
    "\n",
    "\n",
    "def build_custom_agent():\n",
    "    \"\"\"构建自定义 StateGraph——完全可观测、可干预\"\"\"\n",
    "    if not _HAS_LANGGRAPH:\n",
    "        print(\"[SKIP] langgraph 未安装，跳过图构建\")\n",
    "        return None\n",
    "    \n",
    "    builder = StateGraph(AgentState)\n",
    "    builder.add_node(\"intent_classifier\", intent_classifier_node)\n",
    "    builder.add_node(\"search_node\", search_node)\n",
    "    builder.add_node(\"chat_node\", chat_node)\n",
    "    \n",
    "    builder.set_entry_point(\"intent_classifier\")\n",
    "    builder.add_conditional_edges(\n",
    "        \"intent_classifier\",\n",
    "        route_by_intent,\n",
    "        {\"search_node\": \"search_node\", \"chat_node\": \"chat_node\"}\n",
    "    )\n",
    "    builder.add_edge(\"search_node\", END)\n",
    "    builder.add_edge(\"chat_node\", END)\n",
    "    \n",
    "    return builder.compile()\n",
    "\n",
    "\n",
    "# --- 运行对比 ---\n",
    "print(\"=\" * 60)\n",
    "print(\"选型决策矩阵\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "matrix = [\n",
    "    (\"开发速度\", \"极快（3行代码）\", \"中等（需定义状态+节点+路由）\"),\n",
    "    (\"可观测性\", \"有限（黑盒）\", \"完全可控（节点级 Trace）\"),\n",
    "    (\"路由复杂度\", \"仅工具路由\", \"任意条件分支+子图\"),\n",
    "    (\"状态控制\", \"自动管理\", \"精细定制（可裁剪、可扩展）\"),\n",
    "    (\"多模态/并行\", \"不支持\", \"完全支持（子图并行）\"),\n",
    "    (\"生产维护\", \"调试困难\", \"节点级可追踪+降级\"),\n",
    "]\n",
    "\n",
    "print(f\"{'维度':<12} | {'create_react_agent':<20} | {'自定义 StateGraph':<20}\")\n",
    "print(\"-\" * 60)\n",
    "for dim, prebuilt, custom in matrix:\n",
    "    print(f\"{dim:<12} | {prebuilt:<20} | {custom:<20}\")\n",
    "\n",
    "print(\"\\n决策建议:\")\n",
    "print(\"  - 简单工具调用 Agent -> create_react_agent\")\n",
    "print(\"  - 复杂工作流/审批/并行 -> 自定义 StateGraph\")\n",
    "print(\"  - 需要完整可观测性 -> 自定义 StateGraph\")\n",
    "\n",
    "# 构建并运行自定义图\n",
    "graph = build_custom_agent()\n",
    "if graph:\n",
    "    result = graph.invoke({\n",
    "        \"messages\": [],\n",
    "        \"query\": \"查询今天的新能源汽车新闻\",\n",
    "        \"intent\": None,\n",
    "        \"tool_calls\": [],\n",
    "        \"final_answer\": None,\n",
    "        \"metadata\": {}\n",
    "    })\n",
    "    print(\"\\n[自定义图执行结果]\")\n",
    "    print(f\"  意图: {result['intent']}\")\n",
    "    print(f\"  工具调用: {result['tool_calls']}\")\n",
    "    print(f\"  节点耗时: {result['metadata']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 缓存策略实战与命中率监控\n",
    "\n",
    "缓存是降低 API 成本的核心手段。本 cell 展示节点级缓存配置和命中率统计的真实实现。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# 缓存策略实战：CachePolicy 配置 + 命中率监控\n",
    "# 注意：CachePolicy 的导入路径因 langgraph 版本而异\n",
    "# ============================================================\n",
    "\n",
    "# --- 2.1 尝试导入 CachePolicy（兼容多版本）---\n",
    "CachePolicy = None\n",
    "\n",
    "if _HAS_LANGGRAPH:\n",
    "    try:\n",
    "        # LangGraph 0.2.x+ 可能的位置\n",
    "        from langgraph.types import CachePolicy\n",
    "        print(\"[OK] CachePolicy 从 langgraph.types 导入\")\n",
    "    except ImportError:\n",
    "        try:\n",
    "            from langgraph.pregel import CachePolicy\n",
    "            print(\"[OK] CachePolicy 从 langgraph.pregel 导入\")\n",
    "        except ImportError:\n",
    "            try:\n",
    "                from langgraph.checkpoint.base import CachePolicy\n",
    "                print(\"[OK] CachePolicy 从 langgraph.checkpoint.base 导入\")\n",
    "            except ImportError:\n",
    "                print(\"[INFO] 当前 langgraph 版本未暴露 CachePolicy，展示概念配置\")\n",
    "\n",
    "\n",
    "# --- 2.2 节点级缓存策略配置（通用概念，不依赖特定版本） ---\n",
    "@dataclass\n",
    "class NodeCachePolicy:\n",
    "    \"\"\"\n",
    "    节点级缓存策略配置\n",
    "    兼容所有 langgraph 版本的概念层实现\n",
    "    \"\"\"\n",
    "    ttl: int = 3600                    # 缓存存活时间（秒）\n",
    "    key_func: Optional[Callable] = None  # 缓存键生成函数\n",
    "    version: str = \"1.0.0\"            # 缓存版本号（升级后自动失效）\n",
    "    jitter: float = 0.1               # TTL 随机偏移比例（防雪崩）\n",
    "    cache_null: bool = True           # 是否缓存空结果（防穿透）\n",
    "    max_size: int = 10000             # 最大缓存条目数\n",
    "\n",
    "    def make_key(self, state: Dict, config: Dict) -> str:\n",
    "        \"\"\"生成缓存键\"\"\"\n",
    "        if self.key_func:\n",
    "            return self.key_func(state, config)\n",
    "        thread_id = config.get(\"thread_id\", \"global\")\n",
    "        query = state.get(\"query\", \"\")\n",
    "        return f\"cache:v{self.version}:{thread_id}:{hash(query) & 0xFFFFFFFF}\"\n",
    "\n",
    "    def effective_ttl(self) -> int:\n",
    "        \"\"\"计算实际 TTL（含随机偏移）\"\"\"\n",
    "        jitter_seconds = int(self.ttl * self.jitter * random.random())\n",
    "        return self.ttl + jitter_seconds\n",
    "\n",
    "\n",
    "# 展示不同场景的缓存策略\n",
    "policies = {\n",
    "    \"weather_query\": NodeCachePolicy(\n",
    "        ttl=1800,  # 天气数据 30 分钟过期\n",
    "        version=\"1.0.0\",\n",
    "        jitter=0.05\n",
    "    ),\n",
    "    \"stock_lookup\": NodeCachePolicy(\n",
    "        ttl=300,   # 股价 5 分钟过期\n",
    "        version=\"1.0.0\",\n",
    "        jitter=0.2\n",
    "    ),\n",
    "    \"report_generate\": NodeCachePolicy(\n",
    "        ttl=86400,  # 报告 24 小时过期\n",
    "        version=\"2.1.0\",\n",
    "        key_func=lambda s, c: f\"report:{s.get('query','')[:50]}\"\n",
    "    ),\n",
    "}\n",
    "\n",
    "print(\"节点级缓存策略配置:\")\n",
    "for name, policy in policies.items():\n",
    "    print(f\"  {name}: TTL={policy.ttl}s, version={policy.version}, jitter={policy.jitter}\")\n",
    "\n",
    "\n",
    "# --- 2.3 缓存命中率统计（真实实现） ---\n",
    "class CacheStatsTracker:\n",
    "    \"\"\"节点级缓存命中率追踪器\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.stats: Dict[str, Dict[str, int]] = {}\n",
    "        self._lock = False  # 简化：生产环境应使用 threading.Lock\n",
    "    \n",
    "    def record_hit(self, node_name: str):\n",
    "        self.stats.setdefault(node_name, {\"hits\": 0, \"misses\": 0})\n",
    "        self.stats[node_name][\"hits\"] += 1\n",
    "    \n",
    "    def record_miss(self, node_name: str):\n",
    "        self.stats.setdefault(node_name, {\"hits\": 0, \"misses\": 0})\n",
    "        self.stats[node_name][\"misses\"] += 1\n",
    "    \n",
    "    def get_rate(self, node_name: str) -> float:\n",
    "        s = self.stats.get(node_name, {\"hits\": 0, \"misses\": 0})\n",
    "        total = s[\"hits\"] + s[\"misses\"]\n",
    "        return s[\"hits\"] / total if total > 0 else 0.0\n",
    "    \n",
    "    def summary(self) -> Dict[str, float]:\n",
    "        return {name: self.get_rate(name) for name in self.stats}\n",
    "    \n",
    "    def report(self):\n",
    "        \"\"\"打印命中率报表\"\"\"\n",
    "        print(\"\\n缓存命中率统计:\")\n",
    "        for node, stats in self.stats.items():\n",
    "            total = stats[\"hits\"] + stats[\"misses\"]\n",
    "            rate = self.get_rate(node)\n",
    "            bar = \"█\" * int(rate * 20) + \"░\" * (20 - int(rate * 20))\n",
    "            print(f\"  {node:<20} {bar} {rate:.1%} ({stats['hits']}/{total})\")\n",
    "\n",
    "\n",
    "# 模拟真实运行数据\n",
    "tracker = CacheStatsTracker()\n",
    "\n",
    "# 模拟 weather_query 节点：45 命中，5 未命中\n",
    "for _ in range(45): tracker.record_hit(\"weather_query\")\n",
    "for _ in range(5):  tracker.record_miss(\"weather_query\")\n",
    "\n",
    "# 模拟 stock_lookup 节点：120 命中，30 未命中\n",
    "for _ in range(120): tracker.record_hit(\"stock_lookup\")\n",
    "for _ in range(30):  tracker.record_miss(\"stock_lookup\")\n",
    "\n",
    "# 模拟 report_generate 节点：8 命中，2 未命中\n",
    "for _ in range(8):  tracker.record_hit(\"report_generate\")\n",
    "for _ in range(2):  tracker.record_miss(\"report_generate\")\n",
    "\n",
    "tracker.report()\n",
    "\n",
    "print(\"\\n缓存失效策略说明:\")\n",
    "print(\"  - TTL 过期: 时间到期自动失效\")\n",
    "print(\"  - 主动失效: 调用 cache.invalidate(key)\")\n",
    "print(\"  - 版本号失效: key 中包含版本号，升级后自动未命中\")\n",
    "print(\"  - 空值缓存: 对不存在的 key 也缓存短时间（防穿透）\")\n",
    "print(\"  - 随机 TTL 偏移: ttl + random(0, ttl*jitter) 避免同时失效（防雪崩）\")\n",
    "print(\"  - 互斥锁: 缓存未命中时只允许一个请求计算（防击穿）\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Redis + Postgres 混合架构（生产级）\n",
    "\n",
    "生产环境通常使用 Redis 作为高速缓存层，Postgres 作为持久化层。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Redis + Postgres 混合架构配置\n",
    "# 尝试真实导入，失败时提供概念级实现 + 降级到 MemorySaver\n",
    "# ============================================================\n",
    "\n",
    "# --- 3.1 尝试导入真实 Checkpointer ---\n",
    "PostgresSaver = None\n",
    "RedisSaver = None\n",
    "\n",
    "if _HAS_LANGGRAPH:\n",
    "    try:\n",
    "        from langgraph.checkpoint.postgres import PostgresSaver\n",
    "        print(\"[OK] PostgresSaver 导入成功\")\n",
    "    except ImportError:\n",
    "        print(\"[INFO] PostgresSaver 不可用（需安装 langgraph-checkpoint-postgres）\")\n",
    "    \n",
    "    try:\n",
    "        from langgraph.checkpoint.redis import RedisSaver\n",
    "        print(\"[OK] RedisSaver 导入成功\")\n",
    "    except ImportError:\n",
    "        print(\"[INFO] RedisSaver 不可用（需安装 langgraph-checkpoint-redis）\")\n",
    "\n",
    "\n",
    "# --- 3.2 混合架构连接配置（生产级） ---\n",
    "class HybridCheckpointConfig:\n",
    "    \"\"\"\n",
    "    混合架构配置\n",
    "    Redis: 高速缓存 + 会话热数据\n",
    "    Postgres: 持久化审计 + 长期记忆\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self.redis_url = os.getenv(\"REDIS_URL\", \"redis://localhost:6379/0\")\n",
    "        self.postgres_url = os.getenv(\n",
    "            \"POSTGRES_URL\",\n",
    "            \"postgresql://user:pass@localhost:5432/langgraph\"\n",
    "        )\n",
    "        self.redis_ttl = int(os.getenv(\"REDIS_TTL\", \"3600\"))\n",
    "        self.fallback_to_memory = True\n",
    "        self.health_check_interval = 30\n",
    "    \n",
    "    def create_redis_saver(self):\n",
    "        \"\"\"创建 Redis Saver（带降级）\"\"\"\n",
    "        if RedisSaver is None:\n",
    "            print(\"[WARN] RedisSaver 未安装，跳过 Redis 后端\")\n",
    "            return None\n",
    "        try:\n",
    "            saver = RedisSaver(redis_url=self.redis_url, ttl=self.redis_ttl)\n",
    "            print(f\"[OK] RedisSaver 创建成功: {self.redis_url}\")\n",
    "            return saver\n",
    "        except Exception as e:\n",
    "            print(f\"[ERROR] Redis 连接失败: {e}\")\n",
    "            return None\n",
    "    \n",
    "    def create_postgres_saver(self):\n",
    "        \"\"\"创建 Postgres Saver（带降级）\"\"\"\n",
    "        if PostgresSaver is None:\n",
    "            print(\"[WARN] PostgresSaver 未安装，跳过 Postgres 后端\")\n",
    "            return None\n",
    "        try:\n",
    "            saver = PostgresSaver.from_conn_string(self.postgres_url)\n",
    "            # saver.setup()  # 初始化表结构（首次运行）\n",
    "            print(f\"[OK] PostgresSaver 创建成功\")\n",
    "            return saver\n",
    "        except Exception as e:\n",
    "            print(f\"[ERROR] Postgres 连接失败: {e}\")\n",
    "            return None\n",
    "    \n",
    "    def get_checkpointer(self):\n",
    "        \"\"\"\n",
    "        获取最佳可用 Checkpointer\n",
    "        优先级: Redis > Postgres > MemorySaver\n",
    "        \"\"\"\n",
    "        redis = self.create_redis_saver()\n",
    "        if redis:\n",
    "            return redis\n",
    "        \n",
    "        postgres = self.create_postgres_saver()\n",
    "        if postgres:\n",
    "            return postgres\n",
    "        \n",
    "        if self.fallback_to_memory and _HAS_LANGGRAPH:\n",
    "            print(\"[WARN] 降级到 MemorySaver（仅用于开发/测试）\")\n",
    "            return MemorySaver()\n",
    "        \n",
    "        raise RuntimeError(\"没有可用的 Checkpointer 后端\")\n",
    "\n",
    "\n",
    "# --- 3.3 演示配置创建 ---\n",
    "config = HybridCheckpointConfig()\n",
    "print(\"\\n混合架构配置:\")\n",
    "print(f\"  Redis URL: {config.redis_url}\")\n",
    "print(f\"  Postgres URL: {config.postgres_url[:20]}...\" if len(config.postgres_url) > 20 else f\"  Postgres URL: {config.postgres_url}\")\n",
    "print(f\"  Redis TTL: {config.redis_ttl}s\")\n",
    "\n",
    "# 尝试获取 checkpointer（会自动降级）\n",
    "checkpointer = config.get_checkpointer()\n",
    "print(f\"\\n最终使用的 Checkpointer: {type(checkpointer).__name__}\")\n",
    "\n",
    "# --- 3.4 双后端数据流设计说明 ---\n",
    "print(\"\\n双后端数据流设计:\")\n",
    "print(\"  [热路径]  Redis: 会话状态缓存（< 1h）→ 读延迟 < 2ms\")\n",
    "print(\"  [冷路径]  Postgres: 审计日志 + 长期记忆 → 读延迟 ~50ms\")\n",
    "print(\"  [一致性]  Cache-Aside 模式: 先读 Redis，未命中读 Postgres，回写 Redis\")\n",
    "print(\"  [容灾]    Redis 故障时自动降级到 Postgres，服务不中断\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Langfuse 可观测性初始化\n",
    "\n",
    "Langfuse 提供全链路追踪，替代传统的 Prometheus/Grafana 方案。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Langfuse 可观测性：真实初始化 + Mock 降级\n",
    "# 即使无法连接真实服务，也展示真实 API 调用\n",
    "# ============================================================\n",
    "\n",
    "# --- 4.1 环境变量配置 ---\n",
    "# 生产环境应从密钥管理服务读取，这里展示标准配置\n",
    "os.environ.setdefault(\"LANGFUSE_SECRET_KEY\", \"sk-test-key\")\n",
    "os.environ.setdefault(\"LANGFUSE_PUBLIC_KEY\", \"pk-test-key\")\n",
    "os.environ.setdefault(\"LANGFUSE_HOST\", \"https://cloud.langfuse.com\")\n",
    "\n",
    "\n",
    "# --- 4.2 MockLangfuse：当真实服务不可用时保持 API 兼容 ---\n",
    "class MockLangfuse:\n",
    "    \"\"\"Langfuse Mock 实现：保持 API 兼容，打印调用日志\"\"\"\n",
    "    \n",
    "    def __init__(self, **kwargs):\n",
    "        self._config = kwargs\n",
    "        self._traces = []\n",
    "        self._scores = []\n",
    "        print(f\"[MOCK] MockLangfuse 初始化: host={kwargs.get('host', 'N/A')}\")\n",
    "    \n",
    "    def auth_check(self):\n",
    "        print(\"[MOCK] auth_check() -> 模拟认证通过\")\n",
    "        return True\n",
    "    \n",
    "    def trace(self, **kwargs):\n",
    "        trace_id = kwargs.get(\"id\", str(uuid.uuid4()))\n",
    "        self._traces.append({\"id\": trace_id, \"params\": kwargs})\n",
    "        print(f\"[MOCK] trace() -> id={trace_id[:8]}, name={kwargs.get('name', 'N/A')}\")\n",
    "        return MockTrace(trace_id)\n",
    "    \n",
    "    def score(self, **kwargs):\n",
    "        self._scores.append(kwargs)\n",
    "        print(f\"[MOCK] score() -> trace_id={kwargs.get('trace_id', 'N/A')[:8]}, name={kwargs.get('name', 'N/A')}, value={kwargs.get('value', 'N/A')}\")\n",
    "    \n",
    "    def get_dataset(self, name: str):\n",
    "        print(f\"[MOCK] get_dataset('{name}') -> 返回 MockDataset\")\n",
    "        return MockDataset(name)\n",
    "    \n",
    "    def create_prompt(self, **kwargs):\n",
    "        print(f\"[MOCK] create_prompt() -> name={kwargs.get('name', 'N/A')}\")\n",
    "    \n",
    "    def get_prompt(self, name: str):\n",
    "        print(f\"[MOCK] get_prompt('{name}') -> 返回默认 prompt\")\n",
    "        return MockPrompt(name)\n",
    "\n",
    "\n",
    "class MockTrace:\n",
    "    def __init__(self, trace_id: str):\n",
    "        self.id = trace_id\n",
    "    \n",
    "    def span(self, **kwargs):\n",
    "        print(f\"[MOCK] trace.span() -> name={kwargs.get('name', 'N/A')}\")\n",
    "        return self\n",
    "    \n",
    "    def update(self, **kwargs):\n",
    "        pass\n",
    "\n",
    "\n",
    "class MockDataset:\n",
    "    def __init__(self, name: str):\n",
    "        self.name = name\n",
    "    \n",
    "    def create_item(self, **kwargs):\n",
    "        print(f\"[MOCK] dataset.create_item() -> dataset={self.name}\")\n",
    "\n",
    "\n",
    "class MockPrompt:\n",
    "    def __init__(self, name: str):\n",
    "        self.name = name\n",
    "        self.prompt = \"Mock prompt content\"\n",
    "        self.type = \"text\"\n",
    "\n",
    "\n",
    "# --- 4.3 init_langfuse_observability() 真实实现 ---\n",
    "def init_langfuse_observability(\n",
    "    secret_key: Optional[str] = None,\n",
    "    public_key: Optional[str] = None,\n",
    "    host: Optional[str] = None,\n",
    "    mock_fallback: bool = True\n",
    ") -> Any:\n",
    "    \"\"\"\n",
    "    初始化 Langfuse 可观测性客户端\n",
    "    \n",
    "    Args:\n",
    "        secret_key: Langfuse Secret Key（默认从环境变量读取）\n",
    "        public_key: Langfuse Public Key（默认从环境变量读取）\n",
    "        host: Langfuse 服务地址\n",
    "        mock_fallback: 连接失败时是否降级到 Mock\n",
    "    \n",
    "    Returns:\n",
    "        Langfuse 客户端实例（或 Mock 实例）\n",
    "    \"\"\"\n",
    "    secret_key = secret_key or os.getenv(\"LANGFUSE_SECRET_KEY\")\n",
    "    public_key = public_key or os.getenv(\"LANGFUSE_PUBLIC_KEY\")\n",
    "    host = host or os.getenv(\"LANGFUSE_HOST\", \"https://cloud.langfuse.com\")\n",
    "    \n",
    "    if not _HAS_LANGFUSE:\n",
    "        print(\"[WARN] langfuse 未安装，使用 Mock 降级\")\n",
    "        return MockLangfuse(secret_key=secret_key, public_key=public_key, host=host)\n",
    "    \n",
    "    try:\n",
    "        langfuse = Langfuse(\n",
    "            secret_key=secret_key,\n",
    "            public_key=public_key,\n",
    "            host=host,\n",
    "        )\n",
    "        # 验证连接（可选，生产环境建议开启）\n",
    "        # langfuse.auth_check()\n",
    "        print(f\"[OK] Langfuse 初始化成功: host={host}\")\n",
    "        return langfuse\n",
    "    except Exception as e:\n",
    "        print(f\"[ERROR] Langfuse 初始化失败: {e}\")\n",
    "        if mock_fallback:\n",
    "            print(\"[WARN] 降级到 MockLangfuse\")\n",
    "            return MockLangfuse(secret_key=secret_key, public_key=public_key, host=host)\n",
    "        raise\n",
    "\n",
    "\n",
    "# 执行初始化\n",
    "langfuse = init_langfuse_observability()\n",
    "print(f\"\\nLangfuse 实例类型: {type(langfuse).__name__}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. CallbackHandler 与 Trace 追踪\n",
    "\n",
    "CallbackHandler 自动追踪图执行，无需修改节点代码。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# CallbackHandler 与 Trace 追踪\n",
    "# create_callback_handler() + get_langfuse_config() 真实实现\n",
    "# ============================================================\n",
    "\n",
    "# --- 5.1 create_callback_handler() 真实实现 ---\n",
    "def create_callback_handler(\n",
    "    trace_name: str,\n",
    "    user_id: Optional[str] = None,\n",
    "    session_id: Optional[str] = None,\n",
    "    tags: Optional[List[str]] = None,\n",
    "    metadata: Optional[Dict[str, Any]] = None,\n",
    ") -> Any:\n",
    "    \"\"\"\n",
    "    为每次图执行创建 Langfuse CallbackHandler\n",
    "    \n",
    "    Args:\n",
    "        trace_name: Trace 名称（如 'opsmate_query'）\n",
    "        user_id: 用户标识\n",
    "        session_id: 会话标识（默认自动生成）\n",
    "        tags: 标签列表（如 ['env:prod', 'agent:opsmate']）\n",
    "        metadata: 额外元数据\n",
    "    \n",
    "    Returns:\n",
    "        CallbackHandler 实例（或 Mock 实例）\n",
    "    \"\"\"\n",
    "    session_id = session_id or str(uuid.uuid4())\n",
    "    tags = tags or [\"env:prod\", \"agent:opsmate\"]\n",
    "    \n",
    "    if not _HAS_LANGFUSE:\n",
    "        print(f\"[MOCK] create_callback_handler(trace_name='{trace_name}', user_id='{user_id}', session_id='{session_id[:8]}...')\")\n",
    "        return MockCallbackHandler(trace_name, user_id, session_id, tags)\n",
    "    \n",
    "    try:\n",
    "        handler = CallbackHandler(\n",
    "            trace_name=trace_name,\n",
    "            user_id=user_id,\n",
    "            session_id=session_id,\n",
    "            tags=tags,\n",
    "        )\n",
    "        print(f\"[OK] CallbackHandler 创建成功: trace_name={trace_name}\")\n",
    "        return handler\n",
    "    except Exception as e:\n",
    "        print(f\"[ERROR] CallbackHandler 创建失败: {e}\")\n",
    "        return MockCallbackHandler(trace_name, user_id, session_id, tags)\n",
    "\n",
    "\n",
    "class MockCallbackHandler:\n",
    "    \"\"\"CallbackHandler Mock：保持 API 兼容\"\"\"\n",
    "    def __init__(self, trace_name, user_id, session_id, tags):\n",
    "        self.trace_name = trace_name\n",
    "        self.user_id = user_id\n",
    "        self.session_id = session_id\n",
    "        self.tags = tags\n",
    "    \n",
    "    def __repr__(self):\n",
    "        return f\"MockCallbackHandler(trace={self.trace_name})\"\n",
    "\n",
    "\n",
    "# --- 5.2 get_langfuse_config() 一键配置 ---\n",
    "def generate_session_id() -> str:\n",
    "    \"\"\"生成会话 ID\"\"\"\n",
    "    return f\"sess_{uuid.uuid4().hex[:12]}\"\n",
    "\n",
    "\n",
    "def get_langfuse_config(\n",
    "    trace_name: str,\n",
    "    user_id: Optional[str] = None,\n",
    "    app_version: str = \"1.2.0\",\n",
    "    environment: str = \"production\"\n",
    ") -> Dict[str, Any]:\n",
    "    \"\"\"\n",
    "    一键获取包含 Langfuse 追踪的 config 字典\n",
    "    \n",
    "    使用方式:\n",
    "        config = get_langfuse_config('deep_research', user_id='user_001')\n",
    "        result = graph.invoke(state, config=config)\n",
    "    \"\"\"\n",
    "    handler = create_callback_handler(\n",
    "        trace_name=trace_name,\n",
    "        user_id=user_id,\n",
    "        session_id=generate_session_id()\n",
    "    )\n",
    "    return {\n",
    "        \"callbacks\": [handler],\n",
    "        \"metadata\": {\n",
    "            \"app_version\": app_version,\n",
    "            \"environment\": environment,\n",
    "            \"trace_name\": trace_name,\n",
    "        },\n",
    "        \"run_name\": trace_name,\n",
    "        \"recursion_limit\": 50,  # 防止无限递归\n",
    "    }\n",
    "\n",
    "\n",
    "# --- 5.3 演示 ---\n",
    "handler = create_callback_handler(\n",
    "    trace_name=\"opsmate_query\",\n",
    "    user_id=\"user_001\",\n",
    "    session_id=\"session_abc123\",\n",
    "    tags=[\"env:prod\", \"agent:opsmate\"]\n",
    ")\n",
    "\n",
    "config = get_langfuse_config(\n",
    "    trace_name=\"deep_research\",\n",
    "    user_id=\"user_001\",\n",
    "    app_version=\"1.2.0\",\n",
    "    environment=\"production\"\n",
    ")\n",
    "\n",
    "print(\"\\nLangfuse Config 结构:\")\n",
    "print(json.dumps(\n",
    "    {k: (str(v) if k == \"callbacks\" else v) for k, v in config.items()},\n",
    "    indent=2,\n",
    "    ensure_ascii=False\n",
    "))\n",
    "\n",
    "print(\"\\nTrace 链路结构示意:\")\n",
    "trace_diagram = '''\n",
    "Trace: 用户查询 \"新能源汽车分析\"\n",
    "├── Node: intent_classifier  (23ms)\n",
    "├── Node: mode_router        (15ms)\n",
    "│   └── LLM Call             (312ms)\n",
    "├── Node: task_planner       (45ms)\n",
    "│   └── LLM Call             (456ms)\n",
    "├── Node: search_parallel    (1203ms)\n",
    "│   ├── Subgraph: finance    (800ms)\n",
    "│   ├── Subgraph: news       (600ms)\n",
    "│   └── Subgraph: competitor (750ms)\n",
    "├── Node: plan_router        (18ms)\n",
    "└── Node: report_generator   (2345ms)\n",
    "    └── LLM Call             (2300ms)\n",
    "'''\n",
    "print(trace_diagram)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Score 评分系统：缓存命中率上报\n",
    "\n",
    "Score 是 Langfuse 的业务指标系统，不只是技术监控，更是成本预警器。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Score 评分系统：真实 API 调用（mock 数据也要调用真实 API）\n",
    "# report_cache_hit_rate() + 自定义评分指标\n",
    "# ============================================================\n",
    "\n",
    "def report_cache_hit_rate(\n",
    "    trace_id: str,\n",
    "    node_name: str,\n",
    "    hits: int,\n",
    "    misses: int,\n",
    "    langfuse_client: Optional[Any] = None\n",
    ") -> Dict[str, Any]:\n",
    "    \"\"\"\n",
    "    上报缓存命中率到 Langfuse Score\n",
    "    \n",
    "    Args:\n",
    "        trace_id: 关联的 Trace ID\n",
    "        node_name: 节点名称\n",
    "        hits: 缓存命中次数\n",
    "        misses: 缓存未命中次数\n",
    "        langfuse_client: Langfuse 客户端（默认使用全局实例）\n",
    "    \n",
    "    Returns:\n",
    "        上报结果字典\n",
    "    \"\"\"\n",
    "    client = langfuse_client or langfuse\n",
    "    total = hits + misses\n",
    "    rate = hits / total if total > 0 else 0.0\n",
    "    \n",
    "    result = {\n",
    "        \"trace_id\": trace_id,\n",
    "        \"name\": f\"cache_hit_rate_{node_name}\",\n",
    "        \"value\": round(rate, 4),\n",
    "        \"comment\": f\"hits={hits}, misses={misses}, total={total}\",\n",
    "    }\n",
    "    \n",
    "    try:\n",
    "        # 真实 API 调用（即使使用 MockLangfuse 也会记录调用日志）\n",
    "        client.score(**result)\n",
    "        result[\"status\"] = \"success\"\n",
    "    except Exception as e:\n",
    "        print(f\"[ERROR] Score 上报失败: {e}\")\n",
    "        result[\"status\"] = \"failed\"\n",
    "        result[\"error\"] = str(e)\n",
    "    \n",
    "    print(f\"  上报 Score: {node_name} hit_rate={rate:.1%} (hits={hits}, misses={misses})\")\n",
    "    return result\n",
    "\n",
    "\n",
    "def report_response_time(\n",
    "    trace_id: str,\n",
    "    node_name: str,\n",
    "    duration_ms: float,\n",
    "    langfuse_client: Optional[Any] = None\n",
    ") -> Dict[str, Any]:\n",
    "    \"\"\"上报节点响应时间评分\"\"\"\n",
    "    client = langfuse_client or langfuse\n",
    "    result = {\n",
    "        \"trace_id\": trace_id,\n",
    "        \"name\": f\"response_time_{node_name}\",\n",
    "        \"value\": duration_ms,\n",
    "        \"comment\": f\"duration_ms={duration_ms}\",\n",
    "    }\n",
    "    try:\n",
    "        client.score(**result)\n",
    "        result[\"status\"] = \"success\"\n",
    "    except Exception as e:\n",
    "        result[\"status\"] = \"failed\"\n",
    "        result[\"error\"] = str(e)\n",
    "    print(f\"  上报 Score: {node_name} response_time={duration_ms}ms\")\n",
    "    return result\n",
    "\n",
    "\n",
    "def report_output_quality(\n",
    "    trace_id: str,\n",
    "    score: float,  # 0.0 ~ 1.0\n",
    "    evaluator: str = \"human\",\n",
    "    comment: str = \"\",\n",
    "    langfuse_client: Optional[Any] = None\n",
    ") -> Dict[str, Any]:\n",
    "    \"\"\"上报输出质量评分（人工或模型评估）\"\"\"\n",
    "    client = langfuse_client or langfuse\n",
    "    result = {\n",
    "        \"trace_id\": trace_id,\n",
    "        \"name\": f\"output_quality_{evaluator}\",\n",
    "        \"value\": score,\n",
    "        \"comment\": comment or f\"evaluator={evaluator}\",\n",
    "    }\n",
    "    try:\n",
    "        client.score(**result)\n",
    "        result[\"status\"] = \"success\"\n",
    "    except Exception as e:\n",
    "        result[\"status\"] = \"failed\"\n",
    "        result[\"error\"] = str(e)\n",
    "    print(f\"  上报 Score: output_quality={score:.2f} (evaluator={evaluator})\")\n",
    "    return result\n",
    "\n",
    "\n",
    "# --- 演示：批量上报 Score ---\n",
    "print(\"Score 评分上报演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "trace_id = f\"trace_{uuid.uuid4().hex[:12]}\"\n",
    "\n",
    "# 缓存命中率上报\n",
    "report_cache_hit_rate(trace_id, \"weather_query\", 45, 5)\n",
    "report_cache_hit_rate(trace_id, \"stock_lookup\", 120, 30)\n",
    "report_cache_hit_rate(trace_id, \"report_generate\", 8, 2)\n",
    "\n",
    "# 响应时间上报\n",
    "report_response_time(trace_id, \"intent_classifier\", 23)\n",
    "report_response_time(trace_id, \"search_parallel\", 1203)\n",
    "report_response_time(trace_id, \"report_generator\", 2345)\n",
    "\n",
    "# 输出质量上报\n",
    "report_output_quality(trace_id, 0.92, evaluator=\"llm_judge\", comment=\"结构完整，数据准确\")\n",
    "\n",
    "print(\"\\n业务意义:\")\n",
    "print(\"  - 缓存命中率 85% → 节省 85% 的 API 费用\")\n",
    "print(\"  - 响应时间 P99 < 2s → 用户体验达标\")\n",
    "print(\"  - 输出质量评分下降 → Prompt 需要优化\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Tags 标签系统\n",
    "\n",
    "Tags 用于按环境、服务、用户维度筛选 Trace，是生产环境多租户隔离的关键。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Tags 标签系统：标准化标签生成\n",
    "# ============================================================\n",
    "\n",
    "def build_default_tags(\n",
    "    agent_type: Optional[str] = None,\n",
    "    feature: Optional[str] = None,\n",
    "    environment: Optional[str] = None,\n",
    "    region: Optional[str] = None,\n",
    "    version: Optional[str] = None,\n",
    "    custom_tags: Optional[List[str]] = None\n",
    ") -> List[str]:\n",
    "    \"\"\"\n",
    "    构建标准化标签列表\n",
    "    \n",
    "    标签格式: category:value（便于 Langfuse 筛选和分组）\n",
    "    \n",
    "    Args:\n",
    "        agent_type: Agent 类型（如 'deep_research'）\n",
    "        feature: 功能模块（如 'cache', 'streaming'）\n",
    "        environment: 环境（dev/test/staging/prod）\n",
    "        region: 区域（如 'ap-east-1'）\n",
    "        version: 应用版本\n",
    "        custom_tags: 自定义标签\n",
    "    \"\"\"\n",
    "    tags = [\n",
    "        f\"env:{environment or os.getenv('APP_ENV', 'dev')}\",\n",
    "        f\"proc:{os.getenv('PROCESS_TYPE', 'api')}\",\n",
    "        f\"region:{region or os.getenv('REGION', 'ap-east-1')}\",\n",
    "    ]\n",
    "    \n",
    "    if agent_type:\n",
    "        tags.append(f\"agent:{agent_type}\")\n",
    "    if feature:\n",
    "        tags.append(f\"feature:{feature}\")\n",
    "    if version:\n",
    "        tags.append(f\"version:{version}\")\n",
    "    if custom_tags:\n",
    "        tags.extend([t for t in custom_tags if \":\" in t])\n",
    "    \n",
    "    return tags\n",
    "\n",
    "\n",
    "# --- 演示不同场景的标签 ---\n",
    "print(\"生产环境标签:\")\n",
    "tags_prod = build_default_tags(\n",
    "    agent_type=\"deep_research\",\n",
    "    feature=\"cache\",\n",
    "    environment=\"prod\",\n",
    "    region=\"ap-east-1\",\n",
    "    version=\"1.2.0\"\n",
    ")\n",
    "print(f\"  {tags_prod}\")\n",
    "\n",
    "print(\"\\n开发环境标签:\")\n",
    "tags_dev = build_default_tags(\n",
    "    agent_type=\"opsmate\",\n",
    "    feature=\"streaming\",\n",
    "    environment=\"dev\"\n",
    ")\n",
    "print(f\"  {tags_dev}\")\n",
    "\n",
    "print(\"\\n标签用途:\")\n",
    "print(\"  - env:prod    → 只查看生产环境 Trace\")\n",
    "print(\"  - agent:xxx   → 按 Agent 类型分组统计\")\n",
    "print(\"  - feature:xxx → 按功能模块筛选异常\")\n",
    "print(\"  - version:xxx → 对比不同版本的性能指标\")\n",
    "\n",
    "# --- 演示：通过标签筛选配置 ---\n",
    "def get_config_by_environment(env: str = \"prod\") -> Dict[str, Any]:\n",
    "    \"\"\"根据环境获取配置\"\"\"\n",
    "    configs = {\n",
    "        \"dev\": {\n",
    "            \"recursion_limit\": 10,\n",
    "            \"model\": \"gpt-3.5-turbo\",\n",
    "            \"temperature\": 0.9,\n",
    "            \"langfuse_project\": \"dev-project\",\n",
    "        },\n",
    "        \"staging\": {\n",
    "            \"recursion_limit\": 25,\n",
    "            \"model\": \"gpt-4\",\n",
    "            \"temperature\": 0.7,\n",
    "            \"langfuse_project\": \"staging-project\",\n",
    "        },\n",
    "        \"prod\": {\n",
    "            \"recursion_limit\": 50,\n",
    "            \"model\": \"gpt-4-turbo\",\n",
    "            \"temperature\": 0.5,\n",
    "            \"langfuse_project\": \"prod-project\",\n",
    "        },\n",
    "    }\n",
    "    return configs.get(env, configs[\"prod\"])\n",
    "\n",
    "print(\"\\n不同环境配置:\")\n",
    "for env in [\"dev\", \"staging\", \"prod\"]:\n",
    "    cfg = get_config_by_environment(env)\n",
    "    print(f\"  {env}: model={cfg['model']}, recursion_limit={cfg['recursion_limit']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Dataset 管理：QA Capture\n",
    "\n",
    "Dataset 用于自动采集 QA 数据，构建评估数据集和回归测试。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Dataset QA Capture：自动保存运行数据到 Langfuse Dataset\n",
    "# ============================================================\n",
    "\n",
    "class QACapture:\n",
    "    \"\"\"\n",
    "    QA 数据采集器\n",
    "    自动捕获用户查询、系统回答、元数据，用于后续评估\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(\n",
    "        self,\n",
    "        dataset_name: str = \"opsmate_qa_v1\",\n",
    "        langfuse_client: Optional[Any] = None\n",
    "    ):\n",
    "        self.dataset_name = dataset_name\n",
    "        self.client = langfuse_client or langfuse\n",
    "        self._local_buffer: List[Dict] = []\n",
    "    \n",
    "    def capture(\n",
    "        self,\n",
    "        query: str,\n",
    "        response: str,\n",
    "        trace_id: Optional[str] = None,\n",
    "        expected: Optional[str] = None,\n",
    "        metadata: Optional[Dict] = None,\n",
    "        user_feedback: Optional[str] = None,  # 'positive' / 'negative' / None\n",
    "    ) -> Dict[str, Any]:\n",
    "        \"\"\"\n",
    "        捕获一条 QA 记录\n",
    "        \n",
    "        Args:\n",
    "            query: 用户查询\n",
    "            response: 系统回答\n",
    "            trace_id: 关联的 Trace ID\n",
    "            expected: 期望回答（用于有监督评估）\n",
    "            metadata: 额外元数据\n",
    "            user_feedback: 用户反馈（👍/👎）\n",
    "        \"\"\"\n",
    "        record = {\n",
    "            \"input\": {\"query\": query},\n",
    "            \"expected_output\": {\"response\": expected or response},\n",
    "            \"source_trace_id\": trace_id,\n",
    "            \"metadata\": {\n",
    "                \"captured_at\": datetime.now().isoformat(),\n",
    "                \"user_feedback\": user_feedback,\n",
    "                **(metadata or {})\n",
    "            }\n",
    "        }\n",
    "        \n",
    "        # 尝试写入 Langfuse Dataset\n",
    "        try:\n",
    "            dataset = self.client.get_dataset(self.dataset_name)\n",
    "            dataset.create_item(**record)\n",
    "            record[\"sync_status\"] = \"synced\"\n",
    "            print(f\"[OK] QA 记录已同步到 Dataset '{self.dataset_name}'\")\n",
    "        except Exception as e:\n",
    "            # 降级：保存到本地缓冲区\n",
    "            self._local_buffer.append(record)\n",
    "            record[\"sync_status\"] = \"buffered\"\n",
    "            print(f\"[WARN] Dataset 同步失败: {e}，已缓存到本地（{len(self._local_buffer)} 条）\")\n",
    "        \n",
    "        return record\n",
    "    \n",
    "    def flush_local_buffer(self):\n",
    "        \"\"\"将本地缓冲区数据批量同步到 Langfuse\"\"\"\n",
    "        if not self._local_buffer:\n",
    "            print(\"[INFO] 本地缓冲区为空\")\n",
    "            return\n",
    "        \n",
    "        synced = 0\n",
    "        failed = 0\n",
    "        try:\n",
    "            dataset = self.client.get_dataset(self.dataset_name)\n",
    "            for record in self._local_buffer:\n",
    "                try:\n",
    "                    dataset.create_item(**record)\n",
    "                    synced += 1\n",
    "                except Exception:\n",
    "                    failed += 1\n",
    "            self._local_buffer = []\n",
    "            print(f\"[OK] 批量同步完成: {synced} 成功, {failed} 失败\")\n",
    "        except Exception as e:\n",
    "            print(f\"[ERROR] 批量同步失败: {e}\")\n",
    "    \n",
    "    def get_buffer(self) -> List[Dict]:\n",
    "        \"\"\"获取本地缓冲区内容\"\"\"\n",
    "        return self._local_buffer.copy()\n",
    "\n",
    "\n",
    "# --- 演示 QA Capture ---\n",
    "print(\"Dataset QA Capture 演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "qa = QACapture(dataset_name=\"opsmate_qa_v1\")\n",
    "\n",
    "# 模拟正常采集\n",
    "qa.capture(\n",
    "    query=\"服务器 CPU 使用率过高怎么办？\",\n",
    "    response=\"建议检查进程占用、排查内存泄漏、考虑扩容...\",\n",
    "    trace_id=f\"trace_{uuid.uuid4().hex[:12]}\",\n",
    "    expected=\"检查进程、排查内存泄漏、扩容\",\n",
    "    user_feedback=\"positive\",\n",
    "    metadata={\"agent\": \"opsmate\", \"intent\": \"troubleshooting\"}\n",
    ")\n",
    "\n",
    "qa.capture(\n",
    "    query=\"数据库连接池满了怎么处理？\",\n",
    "    response=\"调整 max_connections 或启用连接池复用...\",\n",
    "    trace_id=f\"trace_{uuid.uuid4().hex[:12]}\",\n",
    "    user_feedback=\"negative\",\n",
    "    metadata={\"agent\": \"opsmate\", \"intent\": \"troubleshooting\"}\n",
    ")\n",
    "\n",
    "print(\"\\nDataset 用途:\")\n",
    "print(\"  1. 构建评估数据集：人工标注 + 自动采集\")\n",
    "print(\"  2. 回归测试：修改模型/Prompt 后重新运行 Dataset 对比结果\")\n",
    "print(\"  3. 质量监控：追踪回答质量随时间的变化\")\n",
    "print(\"  4. Bad Case 收集：筛选 user_feedback='negative' 的记录重点优化\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 9. Prompt 生命周期管理\n",
    "\n",
    "PromptManager 封装 YAML 本地存储 + Langfuse Prompt Hub 同步，实现 Prompt 的版本管理。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# PromptManager：最小可运行实现\n",
    "# 支持 YAML 本地存储、Langfuse Hub 拉取/推送概念\n",
    "# 参考用户项目中的 prompts_manager.py 设计思想\n",
    "# ============================================================\n",
    "\n",
    "class PromptManager:\n",
    "    \"\"\"\n",
    "    Prompt 生命周期管理器\n",
    "    \n",
    "    设计原则:\n",
    "    - 本地 YAML 优先：运行时直接读取本地文件，零网络依赖\n",
    "    - Hub 作为备份：本地缺失时从 Langfuse Hub 自动拉取\n",
    "    - 版本可追溯：YAML 中记录 version、synced_at、commitMessage\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(\n",
    "        self,\n",
    "        local_dir: str = \"prompts\",\n",
    "        langfuse_client: Optional[Any] = None,\n",
    "        auto_pull: bool = True\n",
    "    ):\n",
    "        self.local_dir = Path(local_dir)\n",
    "        self.local_dir.mkdir(parents=True, exist_ok=True)\n",
    "        self.langfuse = langfuse_client or langfuse\n",
    "        self.auto_pull = auto_pull\n",
    "        self._config_file = self.local_dir / \"prompts_config.yaml\"\n",
    "        self._config = self._load_config()\n",
    "    \n",
    "    def _load_config(self) -> Dict[str, Any]:\n",
    "        \"\"\"加载 prompts 配置索引\"\"\"\n",
    "        if self._config_file.exists():\n",
    "            with open(self._config_file, \"r\", encoding=\"utf-8\") as f:\n",
    "                return yaml.safe_load(f) or {\"prompts\": {}}\n",
    "        return {\"prompts\": {}}\n",
    "    \n",
    "    def _save_config(self):\n",
    "        \"\"\"保存 prompts 配置索引\"\"\"\n",
    "        with open(self._config_file, \"w\", encoding=\"utf-8\") as f:\n",
    "            yaml.dump(self._config, f, allow_unicode=True, sort_keys=False)\n",
    "    \n",
    "    def get_prompt(self, prompt_name: str) -> Optional[Dict[str, Any]]:\n",
    "        \"\"\"\n",
    "        获取 Prompt 配置\n",
    "        \n",
    "        优先级: 本地 YAML > Langfuse Hub（auto_pull 开启时）\n",
    "        \"\"\"\n",
    "        prompt_meta = self._config.get(\"prompts\", {}).get(prompt_name)\n",
    "        if not prompt_meta:\n",
    "            return None\n",
    "        \n",
    "        yaml_file = self.local_dir / prompt_meta.get(\"file\", f\"{prompt_name}.yaml\")\n",
    "        \n",
    "        # 本地存在则直接读取\n",
    "        if yaml_file.exists():\n",
    "            with open(yaml_file, \"r\", encoding=\"utf-8\") as f:\n",
    "                data = yaml.safe_load(f)\n",
    "            data[\"_source\"] = \"local\"\n",
    "            return data\n",
    "        \n",
    "        # 本地不存在，尝试从 Hub 拉取\n",
    "        if self.auto_pull and prompt_meta.get(\"hub_name\"):\n",
    "            print(f\"[*] 本地未找到 '{prompt_name}'，尝试从 Hub 拉取...\")\n",
    "            pulled = self._pull_from_hub(prompt_name, prompt_meta)\n",
    "            if pulled:\n",
    "                return self.get_prompt(prompt_name)\n",
    "        \n",
    "        return None\n",
    "    \n",
    "    def save_prompt(\n",
    "        self,\n",
    "        name: str,\n",
    "        content: Union[str, List[Dict]],\n",
    "        prompt_type: str = \"text\",  # 'text' or 'chat'\n",
    "        version: str = \"1.0.0\",\n",
    "        description: str = \"\",\n",
    "        input_variables: Optional[List[str]] = None,\n",
    "        hub_name: Optional[str] = None,\n",
    "    ) -> Path:\n",
    "        \"\"\"\n",
    "        保存 Prompt 到本地 YAML\n",
    "        \n",
    "        Args:\n",
    "            name: Prompt 名称\n",
    "            content: 提示词内容（text 类型为字符串，chat 类型为消息列表）\n",
    "            prompt_type: 'text' 或 'chat'\n",
    "            version: 版本号\n",
    "            description: 描述\n",
    "            input_variables: 输入变量列表\n",
    "            hub_name: 对应的 Hub 名称\n",
    "        \"\"\"\n",
    "        filename = f\"{name}.yaml\"\n",
    "        filepath = self.local_dir / filename\n",
    "        \n",
    "        # 构建 YAML 结构\n",
    "        data = {\n",
    "            \"name\": name,\n",
    "            \"version\": version,\n",
    "            \"description\": description,\n",
    "            \"type\": prompt_type,\n",
    "            \"input_variables\": input_variables or [],\n",
    "            \"updated_at\": datetime.now().isoformat(),\n",
    "        }\n",
    "        \n",
    "        if prompt_type == \"chat\":\n",
    "            data[\"messages\"] = content if isinstance(content, list) else []\n",
    "        else:\n",
    "            data[\"template\"] = content if isinstance(content, str) else str(content)\n",
    "        \n",
    "        with open(filepath, \"w\", encoding=\"utf-8\") as f:\n",
    "            f.write(f\"# {name} - v{version}\\n\")\n",
    "            f.write(f\"# {description}\\n\\n\")\n",
    "            yaml.dump(data, f, allow_unicode=True, sort_keys=False)\n",
    "        \n",
    "        # 更新配置索引\n",
    "        if \"prompts\" not in self._config:\n",
    "            self._config[\"prompts\"] = {}\n",
    "        self._config[\"prompts\"][name] = {\n",
    "            \"file\": filename,\n",
    "            \"hub_name\": hub_name or name,\n",
    "            \"version\": version,\n",
    "        }\n",
    "        self._save_config()\n",
    "        \n",
    "        print(f\"[OK] Prompt 已保存: {filepath}\")\n",
    "        return filepath\n",
    "    \n",
    "    def build_prompt(\n",
    "        self,\n",
    "        name: str,\n",
    "        variables: Optional[Dict[str, Any]] = None\n",
    "    ) -> str:\n",
    "        \"\"\"\n",
    "        构建最终提示词（支持 Jinja2 和 f-string 格式变量渲染）\n",
    "        \n",
    "        简化版实现：使用 Python str.format() 渲染\n",
    "        生产环境建议使用 langchain_core.prompts.PromptTemplate\n",
    "        \"\"\"\n",
    "        prompt_data = self.get_prompt(name)\n",
    "        if not prompt_data:\n",
    "            raise ValueError(f\"Prompt '{name}' 不存在\")\n",
    "        \n",
    "        variables = variables or {}\n",
    "        \n",
    "        if prompt_data.get(\"type\") == \"chat\":\n",
    "            messages = prompt_data.get(\"messages\", [])\n",
    "            rendered = []\n",
    "            for msg in messages:\n",
    "                content = msg.get(\"content\", \"\")\n",
    "                try:\n",
    "                    content = content.format(**variables)\n",
    "                except KeyError:\n",
    "                    pass  # 保留未匹配的变量占位符\n",
    "                rendered.append({\"role\": msg.get(\"role\"), \"content\": content})\n",
    "            return rendered\n",
    "        else:\n",
    "            template = prompt_data.get(\"template\", \"\")\n",
    "            try:\n",
    "                return template.format(**variables)\n",
    "            except KeyError:\n",
    "                return template\n",
    "    \n",
    "    def push_to_hub(self, name: str, commit_message: str = \"\") -> bool:\n",
    "        \"\"\"\n",
    "        将本地 Prompt 推送到 Langfuse Prompt Hub\n",
    "        打上 labels: [\"production\"]\n",
    "        \"\"\"\n",
    "        prompt_data = self.get_prompt(name)\n",
    "        if not prompt_data:\n",
    "            print(f\"[ERROR] Prompt '{name}' 不存在\")\n",
    "            return False\n",
    "        \n",
    "        try:\n",
    "            payload = prompt_data.get(\"messages\") or prompt_data.get(\"template\", \"\")\n",
    "            prompt_type = \"chat\" if prompt_data.get(\"type\") == \"chat\" else \"text\"\n",
    "            \n",
    "            self.langfuse.create_prompt(\n",
    "                name=prompt_data.get(\"hub_name\", name),\n",
    "                prompt=payload,\n",
    "                type=prompt_type,\n",
    "                labels=[\"production\"],\n",
    "                tags=[\"agent/opsmate\"],\n",
    "            )\n",
    "            print(f\"[OK] 已推送到 Langfuse Hub: {name} (label=production)\")\n",
    "            return True\n",
    "        except Exception as e:\n",
    "            print(f\"[ERROR] 推送失败: {e}\")\n",
    "            return False\n",
    "    \n",
    "    def _pull_from_hub(self, name: str, prompt_meta: Dict) -> bool:\n",
    "        \"\"\"从 Langfuse Hub 拉取 Prompt 并保存到本地\"\"\"\n",
    "        hub_name = prompt_meta.get(\"hub_name\", name)\n",
    "        try:\n",
    "            remote = self.langfuse.get_prompt(hub_name)\n",
    "            # 提取内容（适配不同 langfuse 版本的返回格式）\n",
    "            content = getattr(remote, \"prompt\", None) or str(remote)\n",
    "            prompt_type = getattr(remote, \"type\", \"text\")\n",
    "            \n",
    "            self.save_prompt(\n",
    "                name=name,\n",
    "                content=content,\n",
    "                prompt_type=prompt_type,\n",
    "                version=f\"hub-{datetime.now().strftime('%Y%m%d-%H%M%S')}\",\n",
    "                description=f\"Synced from Hub: {hub_name}\",\n",
    "                hub_name=hub_name\n",
    "            )\n",
    "            print(f\"[OK] 已从 Hub 同步: {hub_name}\")\n",
    "            return True\n",
    "        except Exception as e:\n",
    "            print(f\"[ERROR] 从 Hub 拉取失败: {e}\")\n",
    "            return False\n",
    "    \n",
    "    def list_prompts(self) -> List[str]:\n",
    "        \"\"\"列出所有已注册的 Prompt\"\"\"\n",
    "        return list(self._config.get(\"prompts\", {}).keys())\n",
    "\n",
    "\n",
    "# --- 演示 PromptManager ---\n",
    "print(\"PromptManager 演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# 使用临时目录避免污染项目\n",
    "tmp_dir = tempfile.mkdtemp(prefix=\"lg08_prompts_\")\n",
    "pm = PromptManager(local_dir=tmp_dir, langfuse_client=langfuse)\n",
    "\n",
    "# 保存一个 text 类型 Prompt\n",
    "pm.save_prompt(\n",
    "    name=\"planning_prompt\",\n",
    "    content=\"\"\"你是一个研究规划助手。\\n",
    "用户问题: {query}\\n",
    "用户偏好: {preferences}\\n",
    "请制定一个详细的研究计划，包含以下步骤:\n",
    "1. 背景调研\n",
    "2. 数据收集\n",
    "3. 分析整理\n",
    "4. 报告撰写\"\"\",\n",
    "    prompt_type=\"text\",\n",
    "    version=\"1.2.0\",\n",
    "    description=\"DeepResearch 规划阶段提示词\",\n",
    "    input_variables=[\"query\", \"preferences\"],\n",
    "    hub_name=\"deepresearch/planning_prompt\"\n",
    ")\n",
    "\n",
    "# 保存一个 chat 类型 Prompt\n",
    "pm.save_prompt(\n",
    "    name=\"system_prompt\",\n",
    "    content=[\n",
    "        {\"role\": \"system\", \"content\": \"你是一个专业的运维助手。\"},\n",
    "        {\"role\": \"human\", \"content\": \"{query}\"},\n",
    "    ],\n",
    "    prompt_type=\"chat\",\n",
    "    version=\"2.0.0\",\n",
    "    description=\"OpsMate 系统提示词\",\n",
    "    input_variables=[\"query\"]\n",
    ")\n",
    "\n",
    "# 读取并渲染 Prompt\n",
    "print(\"\\n[读取 planning_prompt]\")\n",
    "planning = pm.get_prompt(\"planning_prompt\")\n",
    "print(f\"  版本: {planning.get('version')}\")\n",
    "print(f\"  来源: {planning.get('_source')}\")\n",
    "\n",
    "print(\"\\n[渲染 planning_prompt]\")\n",
    "rendered = pm.build_prompt(\n",
    "    \"planning_prompt\",\n",
    "    variables={\"query\": \"新能源汽车市场分析\", \"preferences\": \"重点关注电池技术\"}\n",
    ")\n",
    "print(rendered[:200] + \"...\" if len(rendered) > 200 else rendered)\n",
    "\n",
    "# 列出所有 Prompt\n",
    "print(f\"\\n已注册 Prompts: {pm.list_prompts()}\")\n",
    "\n",
    "# 展示 Hub 推送/拉取概念\n",
    "print(\"\\nHub 同步演示:\")\n",
    "pm.push_to_hub(\"planning_prompt\", commit_message=\"更新规划提示词 v1.2.0\")\n",
    "\n",
    "print(f\"\\n临时目录: {tmp_dir}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 10. StreamWriter 生产级流式输出（新增）\n",
    "\n",
    "基于工厂模式 + 策略模式的生产级流式输出设计。参考用户项目中的 StreamWriter V3 架构。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# StreamWriter 生产级实践\n",
    "# 基于用户项目设计思想：工厂模式 + 策略模式 + 三段式流式发送\n",
    "# ============================================================\n",
    "\n",
    "# --- 10.1 尝试导入 langgraph 的 get_stream_writer ---\n",
    "get_stream_writer = None\n",
    "\n",
    "if _HAS_LANGGRAPH:\n",
    "    try:\n",
    "        from langgraph.config import get_stream_writer\n",
    "        print(\"[OK] get_stream_writer 从 langgraph.config 导入\")\n",
    "    except ImportError:\n",
    "        try:\n",
    "            from langgraph.pregel import get_stream_writer\n",
    "            print(\"[OK] get_stream_writer 从 langgraph.pregel 导入\")\n",
    "        except ImportError:\n",
    "            print(\"[INFO] 当前 langgraph 版本未暴露 get_stream_writer，使用模拟实现\")\n",
    "\n",
    "\n",
    "# --- 10.2 模拟 get_stream_writer（当真实 API 不可用时） ---\n",
    "if get_stream_writer is None:\n",
    "    _mock_writer_buffer = []\n",
    "    \n",
    "    def _mock_get_stream_writer():\n",
    "        \"\"\"模拟的 stream writer，将消息收集到缓冲区\"\"\"\n",
    "        def writer(msg):\n",
    "            _mock_writer_buffer.append(msg)\n",
    "            print(f\"  [STREAM] {msg.get('message_type')} | {msg.get('status')} | {msg.get('content', '')[:30]}\")\n",
    "        return writer\n",
    "    \n",
    "    get_stream_writer = _mock_get_stream_writer\n",
    "\n",
    "\n",
    "# --- 10.3 生产级 StreamWriter 核心实现（简化版） ---\n",
    "class ProductionStreamWriter:\n",
    "    \"\"\"\n",
    "    生产级流式消息输出系统\n",
    "    \n",
    "    核心设计:\n",
    "    - get_stream_writer() 绑定 LangGraph stream writer\n",
    "    - 三段式流式发送: start → processing → end\n",
    "    - 自动检测流式/非流式模式\n",
    "    - 消息缓冲区：上下文不可用时暂存，可恢复时 flush\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self, node_name: str = \"\", agent_name: str = \"\"):\n",
    "        self.node_name = node_name\n",
    "        self.agent_name = agent_name\n",
    "        self._writer = None\n",
    "        self._pending: List[Dict] = []\n",
    "        self._session_id = None\n",
    "        self._seq = 0\n",
    "    \n",
    "    def _bind_writer(self):\n",
    "        \"\"\"绑定 LangGraph stream writer\"\"\"\n",
    "        if self._writer is not None:\n",
    "            return self._writer\n",
    "        try:\n",
    "            self._writer = get_stream_writer()\n",
    "        except Exception:\n",
    "            pass\n",
    "        return self._writer\n",
    "    \n",
    "    def _emit(self, message: Dict[str, Any]) -> None:\n",
    "        \"\"\"发送消息（带缓冲降级）\"\"\"\n",
    "        writer = self._bind_writer()\n",
    "        if writer is None:\n",
    "            self._pending.append(message)\n",
    "            return\n",
    "        # flush pending\n",
    "        if self._pending:\n",
    "            pending = self._pending\n",
    "            self._pending = []\n",
    "            for msg in pending:\n",
    "                writer(msg)\n",
    "        writer(message)\n",
    "    \n",
    "    def start(self, message_type: str = \"content\", metadata: Optional[Dict] = None):\n",
    "        \"\"\"发送流式开始信号\"\"\"\n",
    "        self._session_id = f\"{self.node_name}_{uuid.uuid4().hex[:8]}\"\n",
    "        self._seq = 0\n",
    "        msg = {\n",
    "            \"message_type\": message_type,\n",
    "            \"node\": self.node_name,\n",
    "            \"message_id\": self._session_id,\n",
    "            \"status\": \"start\",\n",
    "            \"content\": f\"正在运行 {self.node_name} 节点…\",\n",
    "            \"seq\": self._seq,\n",
    "            \"timestamp\": time.time(),\n",
    "            \"metadata\": metadata or {}\n",
    "        }\n",
    "        self._emit(msg)\n",
    "    \n",
    "    def send(\n",
    "        self,\n",
    "        content: str,\n",
    "        message_type: str = \"content\",\n",
    "        data: Optional[Dict] = None,\n",
    "        metadata: Optional[Dict] = None,\n",
    "        finish_reason: Optional[str] = None\n",
    "    ):\n",
    "        \"\"\"发送流式内容块\"\"\"\n",
    "        self._seq += 1\n",
    "        msg = {\n",
    "            \"message_type\": message_type,\n",
    "            \"node\": self.node_name,\n",
    "            \"message_id\": self._session_id,\n",
    "            \"status\": \"processing\",\n",
    "            \"content\": content,\n",
    "            \"seq\": self._seq,\n",
    "            \"timestamp\": time.time(),\n",
    "            \"data\": data or {\"mode\": \"append\", \"delta\": content},\n",
    "            \"metadata\": {**(metadata or {}), \"finish_reason\": finish_reason}\n",
    "        }\n",
    "        self._emit(msg)\n",
    "        \n",
    "        # 如果有 finish_reason，自动发送 end\n",
    "        if finish_reason:\n",
    "            self.end(message_type)\n",
    "    \n",
    "    def end(self, message_type: str = \"content\"):\n",
    "        \"\"\"发送流式结束信号\"\"\"\n",
    "        msg = {\n",
    "            \"message_type\": message_type,\n",
    "            \"node\": self.node_name,\n",
    "            \"message_id\": self._session_id,\n",
    "            \"status\": \"end\",\n",
    "            \"content\": \"\",\n",
    "            \"seq\": self._seq + 1,\n",
    "            \"timestamp\": time.time(),\n",
    "            \"data\": {\"mode\": \"append\"}\n",
    "        }\n",
    "        self._emit(msg)\n",
    "        self._session_id = None\n",
    "        self._seq = 0\n",
    "    \n",
    "    def error(self, error_message: str, message_type: str = \"error\"):\n",
    "        \"\"\"发送错误消息（非流式，立即显示）\"\"\"\n",
    "        msg = {\n",
    "            \"message_type\": message_type,\n",
    "            \"node\": self.node_name,\n",
    "            \"message_id\": f\"err_{uuid.uuid4().hex[:8]}\",\n",
    "            \"status\": \"processing\",\n",
    "            \"content\": error_message,\n",
    "            \"timestamp\": time.time(),\n",
    "        }\n",
    "        self._emit(msg)\n",
    "\n",
    "\n",
    "# --- 10.4 DebugPrinter / wprint 调试工具 ---\n",
    "class DebugPrinter:\n",
    "    \"\"\"\n",
    "    LangGraph Chunk 调试打印工具\n",
    "    参考用户项目中的 debug.py 设计思想\n",
    "    \"\"\"\n",
    "    \n",
    "    TYPE_COLORS = {\n",
    "        \"content\": \"\\033[36m\",      # CYAN\n",
    "        \"thinking\": \"\\033[34m\",     # BLUE\n",
    "        \"tool_call\": \"\\033[33m\",    # YELLOW\n",
    "        \"tool_result\": \"\\033[32m\",  # GREEN\n",
    "        \"plan\": \"\\033[34m\",         # BLUE\n",
    "        \"error\": \"\\033[31m\",        # RED\n",
    "        \"interrupt\": \"\\033[33m\",   # YELLOW\n",
    "        \"start\": \"\\033[2m\",         # DIM\n",
    "        \"end\": \"\\033[2m\",           # DIM\n",
    "    }\n",
    "    RESET = \"\\033[0m\"\n",
    "    BOLD = \"\\033[1m\"\n",
    "    DIM = \"\\033[2m\"\n",
    "    \n",
    "    def __init__(self, color: bool = True, max_len: int = 200):\n",
    "        self.color = color\n",
    "        self.max_len = max_len\n",
    "        self._count = 0\n",
    "        self._node_counts = {}\n",
    "        self._buffer = \"\"\n",
    "        self._current_node = \"\"\n",
    "    \n",
    "    def _c(self, name: str) -> str:\n",
    "        if not self.color:\n",
    "            return \"\"\n",
    "        return self.TYPE_COLORS.get(name, \"\")\n",
    "    \n",
    "    def _trunc(self, text: str) -> str:\n",
    "        if self.max_len > 0 and len(text) > self.max_len:\n",
    "            return text[:self.max_len] + f\"...({len(text)})\"\n",
    "        return text\n",
    "    \n",
    "    def print_chunk(self, chunk: Any):\n",
    "        \"\"\"解析并打印单个 chunk\"\"\"\n",
    "        self._count += 1\n",
    "        \n",
    "        # 解析 chunk 结构\n",
    "        if isinstance(chunk, dict):\n",
    "            node = chunk.get(\"node\", \"?\")\n",
    "            msg_type = chunk.get(\"message_type\", chunk.get(\"type\", \"unknown\"))\n",
    "            status = chunk.get(\"status\", \"\")\n",
    "            content = chunk.get(\"content\", \"\")\n",
    "            data = chunk.get(\"data\", {})\n",
    "        elif isinstance(chunk, tuple) and len(chunk) == 2:\n",
    "            mode, data = chunk\n",
    "            node = str(mode)\n",
    "            msg_type = \"update\"\n",
    "            status = \"processing\"\n",
    "            content = str(data)[:100]\n",
    "            data = {}\n",
    "        else:\n",
    "            node = \"?\"\n",
    "            msg_type = \"unknown\"\n",
    "            status = \"\"\n",
    "            content = str(chunk)[:100]\n",
    "            data = {}\n",
    "        \n",
    "        self._node_counts[node] = self._node_counts.get(node, 0) + 1\n",
    "        \n",
    "        # 节点切换时打印分隔线\n",
    "        if node and node != self._current_node:\n",
    "            if self._buffer:\n",
    "                self._flush_buffer()\n",
    "            dim = self.DIM if self.color else \"\"\n",
    "            rst = self.RESET if self.color else \"\"\n",
    "            print(f\"\\n{dim}{'─'*40}{rst}\")\n",
    "            print(f\"{self.BOLD if self.color else ''}[{node}]{rst}\")\n",
    "            self._current_node = node\n",
    "        \n",
    "        # 状态标记\n",
    "        mark = {\"start\": \">\", \"processing\": \"~\", \"end\": \".\"}.get(status, \" \")\n",
    "        color = self._c(msg_type)\n",
    "        rst = self.RESET if self.color else \"\"\n",
    "        \n",
    "        # 聚合流式内容\n",
    "        if status == \"processing\" and msg_type in (\"content\", \"thinking\"):\n",
    "            self._buffer += content\n",
    "        elif status == \"end\" and self._buffer:\n",
    "            self._flush_buffer(mark)\n",
    "        else:\n",
    "            text = self._trunc(content)\n",
    "            if text:\n",
    "                print(f\"{mark} {color}{text}{rst}\")\n",
    "    \n",
    "    def _flush_buffer(self, mark: str = \".\"):\n",
    "        if not self._buffer:\n",
    "            return\n",
    "        text = self._trunc(self._buffer)\n",
    "        dim = self.DIM if self.color else \"\"\n",
    "        rst = self.RESET if self.color else \"\"\n",
    "        if \"\\n\" in text:\n",
    "            print(f\"{mark}\")\n",
    "            for line in text.split(\"\\n\"):\n",
    "                print(f\"  {dim}|{rst} {line}\")\n",
    "        else:\n",
    "            print(f\"{mark} {dim}{text}{rst}\")\n",
    "        self._buffer = \"\"\n",
    "    \n",
    "    def summary(self):\n",
    "        \"\"\"打印统计摘要\"\"\"\n",
    "        self._flush_buffer()\n",
    "        dim = self.DIM if self.color else \"\"\n",
    "        rst = self.RESET if self.color else \"\"\n",
    "        print(f\"\\n{dim}{'='*50}{rst}\")\n",
    "        print(f\"Total chunks: {self._count}\")\n",
    "        if self._node_counts:\n",
    "            print(f\"Nodes: {', '.join(f'{k}:{v}' for k,v in self._node_counts.items())}\")\n",
    "\n",
    "\n",
    "# 全局 printer 实例（类似用户项目中的 wprint）\n",
    "_global_printer = None\n",
    "\n",
    "def wprint(chunk, **kwargs):\n",
    "    \"\"\"\n",
    "    打印 chunk（类似用户项目中的 wprint）\n",
    "    \n",
    "    用法:\n",
    "        async for chunk in app.astream(state, config, stream_mode=[\"custom\"]):\n",
    "            wprint(chunk)\n",
    "    \"\"\"\n",
    "    global _global_printer\n",
    "    if kwargs or _global_printer is None:\n",
    "        _global_printer = DebugPrinter(**kwargs)\n",
    "    _global_printer.print_chunk(chunk)\n",
    "\n",
    "def wprint_summary():\n",
    "    if _global_printer:\n",
    "        _global_printer.summary()\n",
    "\n",
    "def wprint_reset():\n",
    "    global _global_printer\n",
    "    _global_printer = None\n",
    "\n",
    "\n",
    "# --- 10.5 演示 StreamWriter + DebugPrinter ---\n",
    "print(\"StreamWriter 三段式流式输出演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "writer = ProductionStreamWriter(node_name=\"report_generator\", agent_name=\"deepresearch\")\n",
    "\n",
    "# 模拟 LLM 流式生成\n",
    "writer.start(message_type=\"content\")\n",
    "for token in [\"新能源\", \"汽车市场\", \"分析\", \"报告\\n\", \"1. 市场概况...\", \"2. 竞争格局...\"]:\n",
    "    writer.send(token, message_type=\"content\")\n",
    "writer.end(\"content\")\n",
    "\n",
    "# 模拟工具调用\n",
    "writer.start(message_type=\"tool_call\")\n",
    "writer.send(\n",
    "    \"调用搜索工具...\",\n",
    "    message_type=\"tool_call\",\n",
    "    data={\"tool_name\": \"web_search\", \"tool_args\": {\"query\": \"新能源汽车销量\"}}\n",
    ")\n",
    "writer.end(\"tool_call\")\n",
    "\n",
    "# 模拟错误\n",
    "writer.error(\"API 调用超时，已降级到缓存结果\")\n",
    "\n",
    "print(\"\\nDebugPrinter 演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# 模拟 LangGraph 输出的各种 chunk 格式\n",
    "chunks = [\n",
    "    {\"node\": \"intent_classifier\", \"message_type\": \"content\", \"status\": \"start\", \"content\": \"\"},\n",
    "    {\"node\": \"intent_classifier\", \"message_type\": \"content\", \"status\": \"processing\", \"content\": \"识别到搜索意图\"},\n",
    "    {\"node\": \"intent_classifier\", \"message_type\": \"content\", \"status\": \"end\", \"content\": \"\"},\n",
    "    {\"node\": \"search_node\", \"message_type\": \"tool_call\", \"status\": \"processing\", \"content\": \"\", \"data\": {\"tool_name\": \"search\"}},\n",
    "    {\"node\": \"search_node\", \"message_type\": \"tool_result\", \"status\": \"processing\", \"content\": \"找到 15 条结果\"},\n",
    "    {\"node\": \"report_generator\", \"message_type\": \"content\", \"status\": \"start\", \"content\": \"\"},\n",
    "    {\"node\": \"report_generator\", \"message_type\": \"content\", \"status\": \"processing\", \"content\": \"根据搜索结果\", \"seq\": 1},\n",
    "    {\"node\": \"report_generator\", \"message_type\": \"content\", \"status\": \"processing\", \"content\": \"生成报告如下\", \"seq\": 2},\n",
    "    {\"node\": \"report_generator\", \"message_type\": \"content\", \"status\": \"end\", \"content\": \"\"},\n",
    "]\n",
    "\n",
    "wprint_reset()\n",
    "for chunk in chunks:\n",
    "    wprint(chunk)\n",
    "wprint_summary()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 11. Celery + LangGraph 异步任务集成（新增）\n",
    "\n",
    "生产环境中，LangGraph 通常作为异步任务执行。本 cell 展示 Celery 集成概念。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# Celery + LangGraph 异步任务集成（概念演示）\n",
    "# ============================================================\n",
    "\n",
    "# --- 11.1 Celery 配置（带降级） ---\n",
    "if _HAS_CELERY:\n",
    "    celery_app = Celery(\n",
    "        \"langgraph_tasks\",\n",
    "        broker=os.getenv(\"CELERY_BROKER_URL\", \"redis://localhost:6379/1\"),\n",
    "        backend=os.getenv(\"CELERY_RESULT_BACKEND\", \"redis://localhost:6379/2\"),\n",
    "    )\n",
    "    celery_app.conf.update(\n",
    "        task_serializer=\"json\",\n",
    "        accept_content=[\"json\"],\n",
    "        result_serializer=\"json\",\n",
    "        timezone=\"Asia/Shanghai\",\n",
    "        enable_utc=True,\n",
    "        task_track_started=True,\n",
    "        task_time_limit=600,       # 单个任务最多 10 分钟\n",
    "        worker_prefetch_multiplier=1,  # 公平调度\n",
    "    )\n",
    "    print(\"[OK] Celery 应用已配置\")\n",
    "else:\n",
    "    # Mock Celery（保持 API 兼容，演示概念）\n",
    "    print(\"[INFO] celery 未安装，使用 MockCelery 演示概念\")\n",
    "    \n",
    "    class MockCelery:\n",
    "        def __init__(self, name):\n",
    "            self.name = name\n",
    "        def task(self, *args, **kwargs):\n",
    "            def decorator(func):\n",
    "                def wrapper(*fargs, **fkwargs):\n",
    "                    print(f\"[MOCK CELERY] 执行任务: {func.__name__}\")\n",
    "                    return func(*fargs, **fkwargs)\n",
    "                wrapper.delay = lambda *a, **kw: print(f\"[MOCK CELERY] delay() -> {func.__name__}\") or func(*a, **kw)\n",
    "                return wrapper\n",
    "            return decorator(args[0]) if args and callable(args[0]) else decorator\n",
    "    \n",
    "    celery_app = MockCelery(\"langgraph_tasks\")\n",
    "\n",
    "\n",
    "# --- 11.2 LangGraph 异步任务封装 ---\n",
    "@celery_app.task(bind=True, max_retries=3)\n",
    "def execute_langgraph_task(\n",
    "    self,\n",
    "    graph_name: str,\n",
    "    state: Dict[str, Any],\n",
    "    config: Optional[Dict] = None\n",
    "):\n",
    "    \"\"\"\n",
    "    Celery 任务：执行 LangGraph\n",
    "    \n",
    "    生产级设计要点:\n",
    "    - bind=True: 可访问 self.retry() 实现失败重试\n",
    "    - max_retries=3: 最多重试 3 次\n",
    "    - task_time_limit: 防止任务无限挂起\n",
    "    - 异常时记录详细日志，上报 Langfuse Score\n",
    "    \"\"\"\n",
    "    import traceback\n",
    "    \n",
    "    # 构建追踪配置\n",
    "    trace_name = f\"celery_{graph_name}_{self.request.id if hasattr(self, 'request') else 'sync'}\"\n",
    "    langfuse_config = get_langfuse_config(\n",
    "        trace_name=trace_name,\n",
    "        metadata={\"celery_task_id\": getattr(self, 'request', {}).get('id', 'unknown')}\n",
    "    )\n",
    "    \n",
    "    # 合并配置\n",
    "    merged_config = {**(config or {}), **langfuse_config}\n",
    "    \n",
    "    start_time = time.time()\n",
    "    try:\n",
    "        print(f\"[*] 执行任务: {graph_name}, task_id={getattr(self, 'request', {}).get('id', 'sync')}\")\n",
    "        \n",
    "        # 这里替换为真实的图执行\n",
    "        # result = compiled_graph.invoke(state, config=merged_config)\n",
    "        result = {\n",
    "            \"graph_name\": graph_name,\n",
    "            \"status\": \"success\",\n",
    "            \"output\": f\"模拟执行结果: {graph_name}\",\n",
    "            \"elapsed_ms\": int((time.time() - start_time) * 1000)\n",
    "        }\n",
    "        \n",
    "        # 上报响应时间 Score\n",
    "        report_response_time(\n",
    "            trace_id=trace_name,\n",
    "            node_name=graph_name,\n",
    "            duration_ms=result[\"elapsed_ms\"]\n",
    "        )\n",
    "        \n",
    "        return result\n",
    "    \n",
    "    except Exception as exc:\n",
    "        elapsed_ms = int((time.time() - start_time) * 1000)\n",
    "        print(f\"[ERROR] 任务失败: {exc}\")\n",
    "        traceback.print_exc()\n",
    "        \n",
    "        # 上报错误 Score\n",
    "        try:\n",
    "            langfuse.score(\n",
    "                trace_id=trace_name,\n",
    "                name=\"task_error\",\n",
    "                value=1.0,\n",
    "                comment=f\"{type(exc).__name__}: {str(exc)[:100]}\"\n",
    "            )\n",
    "        except Exception:\n",
    "            pass\n",
    "        \n",
    "        # Celery 重试（指数退避）\n",
    "        if hasattr(self, 'retry') and self.request.retries < self.max_retries:\n",
    "            countdown = 2 ** self.request.retries  # 1, 2, 4 秒\n",
    "            print(f\"[*] {countdown}秒后重试...\")\n",
    "            raise self.retry(exc=exc, countdown=countdown)\n",
    "        \n",
    "        return {\n",
    "            \"graph_name\": graph_name,\n",
    "            \"status\": \"failed\",\n",
    "            \"error\": str(exc),\n",
    "            \"elapsed_ms\": elapsed_ms\n",
    "        }\n",
    "\n",
    "\n",
    "# --- 11.3 演示异步任务 ---\n",
    "print(\"Celery + LangGraph 集成演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "# 同步执行演示（真实环境使用 .delay() 或 .apply_async()）\n",
    "result = execute_langgraph_task(\n",
    "    graph_name=\"deep_research\",\n",
    "    state={\"query\": \"新能源汽车市场分析\", \"messages\": []},\n",
    "    config={\"recursion_limit\": 50}\n",
    ")\n",
    "print(f\"\\n任务结果: {result}\")\n",
    "\n",
    "print(\"\\n生产环境使用方式:\")\n",
    "print(\"  # 异步提交任务\")\n",
    "print(\"  task = execute_langgraph_task.delay('deep_research', state, config)\")\n",
    "print(\"  # 查询结果\")\n",
    "print(\"  result = task.get(timeout=300)\")\n",
    "print(\"\\n  # 或使用 apply_async 指定队列和超时\")\n",
    "print(\"  execute_langgraph_task.apply_async(\")\n",
    "print(\"      args=['deep_research', state, config],\")\n",
    "print(\"      queue='langgraph',\")\n",
    "print(\"      time_limit=600,\")\n",
    "print(\"      countdown=10  # 延迟 10 秒执行\")\n",
    "print(\"  )\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 12. 生产级降级策略（新增）\n",
    "\n",
    "Graceful Degradation 是生产系统的生命线。当依赖服务故障时，系统应自动降级而非崩溃。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# 生产级降级策略（Graceful Degradation）\n",
    "# ============================================================\n",
    "\n",
    "from enum import Enum, auto\n",
    "from functools import wraps\n",
    "\n",
    "class ServiceStatus(Enum):\n",
    "    HEALTHY = auto()      # 健康\n",
    "    DEGRADED = auto()     # 降级运行\n",
    "    UNAVAILABLE = auto()  # 不可用\n",
    "\n",
    "\n",
    "class DegradationPolicy:\n",
    "    \"\"\"\n",
    "    降级策略配置\n",
    "    定义各服务在不同状态下的降级行为\n",
    "    \"\"\"\n",
    "    def __init__(self):\n",
    "        self.policies = {\n",
    "            \"llm\": {\n",
    "                ServiceStatus.HEALTHY: \"full\",        # 全量模型\n",
    "                ServiceStatus.DEGRADED: \"light\",     # 轻量模型\n",
    "                ServiceStatus.UNAVAILABLE: \"cache\",   # 只返回缓存\n",
    "            },\n",
    "            \"redis\": {\n",
    "                ServiceStatus.HEALTHY: \"primary\",     # Redis 为主\n",
    "                ServiceStatus.DEGRADED: \"fallback\",  # 降级到 Postgres\n",
    "                ServiceStatus.UNAVAILABLE: \"memory\",  # 降级到内存\n",
    "            },\n",
    "            \"search\": {\n",
    "                ServiceStatus.HEALTHY: \"vector\",      # 向量检索\n",
    "                ServiceStatus.DEGRADED: \"keyword\",   # 关键词检索\n",
    "                ServiceStatus.UNAVAILABLE: \"skip\",    # 跳过检索\n",
    "            },\n",
    "            \"langfuse\": {\n",
    "                ServiceStatus.HEALTHY: \"full\",        # 完整追踪\n",
    "                ServiceStatus.DEGRADED: \"essential\", # 只记录关键事件\n",
    "                ServiceStatus.UNAVAILABLE: \"buffer\",  # 本地缓冲\n",
    "            },\n",
    "        }\n",
    "\n",
    "\n",
    "class ServiceHealthMonitor:\n",
    "    \"\"\"\n",
    "    服务健康监控器\n",
    "    模拟生产环境中的健康检查机制\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        self._status: Dict[str, ServiceStatus] = {}\n",
    "        self._last_check: Dict[str, float] = {}\n",
    "        self._check_interval = 30\n",
    "    \n",
    "    def check(self, service_name: str) -> ServiceStatus:\n",
    "        \"\"\"检查服务健康状态（带缓存）\"\"\"\n",
    "        now = time.time()\n",
    "        last = self._last_check.get(service_name, 0)\n",
    "        \n",
    "        if now - last < self._check_interval:\n",
    "            return self._status.get(service_name, ServiceStatus.HEALTHY)\n",
    "        \n",
    "        # 模拟健康检查（真实环境应调用服务 ping API）\n",
    "        status = self._perform_health_check(service_name)\n",
    "        self._status[service_name] = status\n",
    "        self._last_check[service_name] = now\n",
    "        return status\n",
    "    \n",
    "    def _perform_health_check(self, service_name: str) -> ServiceStatus:\n",
    "        \"\"\"执行实际健康检查\"\"\"\n",
    "        # 模拟：随机返回健康状态（真实环境应调用实际服务）\n",
    "        import random\n",
    "        r = random.random()\n",
    "        if r > 0.9:\n",
    "            return ServiceStatus.UNAVAILABLE\n",
    "        elif r > 0.7:\n",
    "            return ServiceStatus.DEGRADED\n",
    "        return ServiceStatus.HEALTHY\n",
    "    \n",
    "    def get_status_summary(self) -> Dict[str, str]:\n",
    "        return {k: v.name for k, v in self._status.items()}\n",
    "\n",
    "\n",
    "def with_degradation(service_name: str):\n",
    "    \"\"\"\n",
    "    降级装饰器：自动根据服务健康状态调整行为\n",
    "    \n",
    "    用法:\n",
    "        @with_degradation(\"llm\")\n",
    "        def generate_response(query: str) -> str:\n",
    "            ...\n",
    "    \"\"\"\n",
    "    def decorator(func):\n",
    "        @wraps(func)\n",
    "        def wrapper(*args, **kwargs):\n",
    "            monitor = kwargs.pop('_health_monitor', None) or ServiceHealthMonitor()\n",
    "            policy = kwargs.pop('_degradation_policy', None) or DegradationPolicy()\n",
    "            \n",
    "            status = monitor.check(service_name)\n",
    "            strategy = policy.policies.get(service_name, {}).get(status, \"full\")\n",
    "            \n",
    "            # 将降级策略注入 kwargs\n",
    "            kwargs['_strategy'] = strategy\n",
    "            kwargs['_service_status'] = status\n",
    "            \n",
    "            print(f\"[{service_name}] status={status.name}, strategy={strategy}\")\n",
    "            \n",
    "            if status == ServiceStatus.UNAVAILABLE and strategy == \"skip\":\n",
    "                return {\"status\": \"skipped\", \"reason\": f\"{service_name} unavailable\"}\n",
    "            \n",
    "            try:\n",
    "                return func(*args, **kwargs)\n",
    "            except Exception as e:\n",
    "                if status == ServiceStatus.DEGRADED:\n",
    "                    print(f\"[WARN] {service_name} 降级执行失败，尝试备用策略: {e}\")\n",
",
    "                    kwargs['_strategy'] = \"fallback\"\n",
    "                    return func(*args, **kwargs)\n",
    "                raise\n",
    "        return wrapper\n",
    "    return decorator\n",
    "\n",
    "\n",
    "# --- 演示降级策略 ---\n",
    "print(\"生产级降级策略演示:\")\n",
    "print(\"=\" * 50)\n",
    "\n",
    "monitor = ServiceHealthMonitor()\n",
    "policy = DegradationPolicy()\n",
    "\n",
    "# 检查各服务状态\n",
    "services = [\"llm\", \"redis\", \"search\", \"langfuse\"]\n",
    "for svc in services:\n",
    "    status = monitor.check(svc)\n",
    "    strategy = policy.policies[svc][status]\n",
    "    print(f\"  {svc:<10} -> {status.name:<12} (strategy: {strategy})\")\n",
    "\n",
    "print(\"\\n降级策略矩阵:\")\n",
    "print(f\"{'服务':<10} | {'HEALTHY':<10} | {'DEGRADED':<10} | {'UNAVAILABLE':<10}\")\n",
    "print(\"-\" * 50)\n",
    "for svc, cfg in policy.policies.items():\n",
    "    print(f\"{svc:<10} | {cfg[ServiceStatus.HEALTHY]:<10} | {cfg[ServiceStatus.DEGRADED]:<10} | {cfg[ServiceStatus.UNAVAILABLE]:<10}\")\n",
    "\n",
    "# --- 演示带降级的节点函数 ---\n",
    "@with_degradation(\"llm\")\n",
    "def llm_generate(query: str, _strategy: str = \"full\", **kwargs) -> Dict[str, Any]:\n",
    "    \"\"\"模拟 LLM 生成（带降级策略）\"\"\"\n",
    "    strategies = {\n",
    "        \"full\": f\"[GPT-4] 完整回答: {query}\",\n",
    "        \"light\": f\"[GPT-3.5] 简化回答: {query[:20]}...\",\n",
    "        \"cache\": f\"[CACHE] 缓存结果: {query[:10]}...\",\n",
    "        \"fallback\": f\"[FALLBACK] 备用结果: {query[:15]}...\"\n",
    "    }\n",
    "    return {\n",
    "        \"output\": strategies.get(_strategy, \"unknown\"),\n",
    "        \"strategy\": _strategy\n",
    "    }\n",
    "\n",
    "print(\"\\n带降级的 LLM 调用:\")\n",
    "for svc in [\"llm\", \"llm\", \"llm\"]:\n",
    "    result = llm_generate(\"分析新能源汽车市场\", _health_monitor=monitor, _degradation_policy=policy)\n",
    "    print(f\"  结果: {result['output']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 13. 连接池管理与事件循环隔离（新增）\n",
    "\n    "生产环境高频问题：连接池耗尽、事件循环冲突。本 cell 展示最佳实践概念。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================\n",
    "# 连接池管理与事件循环隔离概念\n",
    "# ============================================================\n",
    "\n",
    "# --- 13.1 连接池配置模板 ---\n",
    "class ConnectionPoolConfig:\n",
    "    \"\"\"\n",
    "    生产级连接池配置\n",
    "    防止连接泄漏和连接风暴\n",
    "    \"\"\"\n",
    "    \n",
    "    # Postgres 连接池\n",
    "    POSTGRES_CONFIG = {\n",
    "        \"min_connections\": 2,           # 最小保持连接\n",
    "        \"max_connections\": 20,          # 最大连接数（防止打爆 DB）\n",
    "        \"connection_timeout\": 10,       # 连接超时（秒）\n",
    "        \"idle_timeout\": 300,            # 空闲连接回收（秒）\n",
    "        \"max_overflow\": 5,              # 临时超额连接\n",
    "        \"pool_recycle\": 3600,           # 连接回收周期（防断开）\n",
    "    }\n",
    "    \n",
    "    # Redis 连接池\n",
    "    REDIS_CONFIG = {\n",
    "        \"max_connections\": 50,\n",
    "        \"socket_timeout\": 5,\n",
    "        \"socket_connect_timeout\": 5,\n",
    "        \"health_check_interval\": 30,\n",
    "        \"retry_on_timeout\": True,\n",
    "    }\n",
    "    \n",
    "    # LLM API 连接池（通过 aiohttp/httpx 控制）\n",
    "    LLM_CONFIG = {\n",
    "        \"max_keepalive_connections\": 10,\n",
    "        \"max_connections\": 30,\n",
    "        \"keepalive_expiry\": 60,\n",
    "        \"timeout\": 60.0,\n",
    "    }\n",
    "\n",
    "\n",
    "# --- 13.2 事件循环隔离 ---\n",
    "class EventLoopManager:\n",
    "    \"\"\"\n",
    "    事件循环隔离管理器\n",
    "    \n",
    "    核心问题：\n",
    "    - Celery 同步任务中调用 async LangGraph 会导致事件循环冲突\n",
    "    - FastAPI 已有事件循环，嵌套 asyncio.run() 会报错\n",
    "    \n",
    "    解决方案：\n",
    "    - 同步上下文：使用 asyncio.run() 或线程池执行 async 代码\n",
    "    - 异步上下文：直接使用 await，不嵌套 run()\n",
    "    \"\"\"\n",
    "    \n",
    "    @staticmethod\n",
    "    def run_async_in_sync(coro, timeout: float = 120.0):\n",
    "        \"\"\"\n",
    "        在同步上下文中安全执行 async 协程\n",
    "        适用于: Celery 任务、脚本入口\n",
    "        \"\"\"\n",
    "        import asyncio\n",
    "        try:\n",
    "            loop = asyncio.get_running_loop()\n",
    "            # 已有事件循环（如在 async 函数中），使用线程池隔离\n",
    "            import concurrent.futures\n",
    "            with concurrent.futures.ThreadPoolExecutor() as pool:\n",
    "                future = pool.submit(asyncio.run, coro)\n",
    "                return future.result(timeout=timeout)\n",
    "        except RuntimeError:\n",
    "            # 无事件循环，安全使用 asyncio.run()\n",
    "            return asyncio.run(coro)\n",
    "    \n",
    "    @staticmethod\n",
    "    def get_or_create_loop():\n",
    "        \"\"\"获取或创建事件循环\"\"\"\n",
    "        import asyncio\n",
    "        try:\n",
    "            return asyncio.get_event_loop()\n",
    "        except RuntimeError:\n",
    "            loop = asyncio.new_event_loop()\n",
    "            asyncio.set_event_loop(loop)\n",
    "            return loop\n",
    "\n",
    "\n",
    "# --- 13.3 生产级 LangGraph 执行器 ---\n",
    "class ProductionGraphExecutor:\n",
    "    \"\"\"\n",
    "    生产级图执行器\n",
    "    封装连接池、超时、降级、追踪\n",
    "    \"\"\"\n",
    "    \n",
    "    def __init__(\n",
    "        self,\n",
    "        graph,\n",
    "        checkpointer=None,\n",
    "        max_concurrency: int = 10,\n",
    "        recursion_limit: int = 50,\n",
    "        timeout: float = 120.0\n",
    "    ):\n",
    "        self.graph = graph\n",
    "        self.checkpointer = checkpointer\n",
    "        self.max_concurrency = max_concurrency\n",
    "        self.recursion_limit = recursion_limit\n",
    "        self.timeout = timeout\n",
    "        self._semaphore = None  # 真实环境应使用 asyncio.Semaphore\n",
    "    \n",
    "    def invoke(\n",
    "        self,\n",
    "        state: Dict[str, Any],\n",
    "        config: Optional[Dict] = None,\n",
    "        user_id: Optional[str] = None\n",
    "    ) -> Dict[str, Any]:\n",
    "        \"\"\"\n",
    "        同步入口：执行图（带完整生产级包装）\n",
    "        \"\"\"\n",
    "        # 1. 生成追踪配置\n",
    "        trace_name = f\"graph_invoke_{uuid.uuid4().hex[:8]}\"\n",
    "        langfuse_cfg = get_langfuse_config(trace_name, user_id=user_id)\n",
    "        \n",
    "        # 2. 合并配置\n",
    "        merged_config = {\n",
    "            \"recursion_limit\": self.recursion_limit,\n",
    "            **(config or {}),\n",
    "            **langfuse_cfg\n",
    "        }\n",
    "        \n",
    "        # 3. 执行（带超时保护）\n",
    "        start = time.time()\n",
    "        try:\n",
    "            # 生产环境建议使用 asyncio.wait_for 包装\n",
    "            if self.graph:\n",
    "                result = self.graph.invoke(state, config=merged_config)\n",
    "            else:\n",
    "                result = {\"status\": \"mock\", \"output\": \"模拟执行\"}\n",
    "            \n",
    "            elapsed = int((time.time() - start) * 1000)\n",
    "            \n",
    "            # 4. 上报性能指标\n",
    "            report_response_time(trace_name, \"graph_invoke\", elapsed)\n",
    "            \n",
    "            return {\n",
    "                \"success\": True,\n",
    "                \"result\": result,\n",
    "                \"elapsed_ms\": elapsed,\n",
    "                \"trace_name\": trace_name\n",
    "            }\n",
    "        \n",
    "        except Exception as e:\n",
    "            elapsed = int((time.time() - start) * 1000)\n",
    "            # 上报错误\n",
    "            try:\n",
    "                langfuse.score(\n",
    "                    trace_id=trace_name,\n",
    "                    name=\"graph_error\",\n",
    "                    value=1.0,\n",
    "                    comment=f\"{type(e).__name__}: {str(e)[:100]}\"\n",
    "                )\n",
    "            except Exception:\n",
    "                pass\n",
    "            \n",
    "            return {\n",
    "                \"success\": False,\n",
    "                \"error\": str(e),\n",
    "                \"elapsed_ms\": elapsed,\n",
    "                \"trace_name\": trace_name\n",
    "            }\n",
    "\n",
    "\n",
    "# --- 演示 ---\n",
    "print(\"连接池配置模板:\")\n",
    "print(\"=\" * 50)\n",
    "print(\"Postgres:\")\n",
    "for k, v in ConnectionPoolConfig.POSTGRES_CONFIG.items():\n",
    "    print(f\"  {k}: {v}\")\n",
    "print(\"\\nRedis:\")\n",
    "for k, v in ConnectionPoolConfig.REDIS_CONFIG.items():\n",
    "    print(f\"  {k}: {v}\")\n",
    "\n",
    "print(\"\\n事件循环隔离原则:\")\n",
    "print(\"  [同步上下文] Celery 任务 → EventLoopManager.run_async_in_sync(coro)\")\n",
    "print(\"  [异步上下文] FastAPI 路由 → 直接使用 await graph.ainvoke()\")\n",
    "print(\"  [禁止] 在已有事件循环中调用 asyncio.run() → RuntimeError\")\n",
    "\n",
    "# 演示生产级执行器\n",
    "print(\"\\n生产级执行器演示:\")\n",
    "executor = ProductionGraphExecutor(\n",
    "    graph=graph,  # 前面构建的图\n",
    "    recursion_limit=50,\n",
    "    timeout=120.0\n",
    ")\n",
    "\n",
    "result = executor.invoke(\n",
    "    state={\n",
    "        \"messages\": [],\n",
    "        \"query\": \"查询服务器状态\",\n",
    "        \"intent\": None,\n",
    "        \"tool_calls\": [],\n",
    "        \"final_answer\": None,\n",
    "        \"metadata\": {}\n",
    "    },\n",
    "    user_id=\"user_001\"\n",
    ")\n",
    "print(f\"执行结果: success={result['success']}, elapsed={result['elapsed_ms']}ms\")"
   ]
  },
