    "\n",
    "try:\n",
    "    import psycopg2\n",
    "    _HAS_PSYCOPG = True\n",
    "    print(\"[OK] psycopg2 已安装\")\n",
    "except ImportError:\n",
    "    print(\"[WARN] psycopg2 未安装\")\n",
    "\n",
    "try:\n",
    "    from celery import Celery\n",
    "    _HAS_CELERY = True\n",
    "    print(\"[OK] celery 已安装\")\n",
    "except ImportError:\n",
    "    print(\"[WARN] celery 未安装\")\n",
    "\n",
    "print(\"\\n环境检测完成，后续代码将自动适配可用依赖。\")"
   ]
