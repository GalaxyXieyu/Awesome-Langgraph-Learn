    "import uuid\n",
    "import tempfile\n",
    "from pathlib import Path\n",
    "from dataclasses import dataclass, field\n",
    "from typing import Any, Dict, List, Optional, Set, Callable, Union\n",
    "from datetime import datetime\n",
    "\n",
    "# --- 核心依赖检测 ---\n",
    "_HAS_LANGGRAPH = False\n",
    "_HAS_LANGFUSE = False\n",
    "_HAS_YAML = False\n",
    "_HAS_REDIS = False\n",
    "_HAS_PSYCOPG = False\n",
    "_HAS_CELERY = False\n",
    "\n",
    "try:\n",
    "    import langgraph\n",
    "    from langgraph.graph import StateGraph, END\n",
    "    from langgraph.checkpoint.memory import MemorySaver\n",
    "    _HAS_LANGGRAPH = True\n",
    "    print(f\"[OK] langgraph {langgraph.__version__} 已安装\")\n",
    "except ImportError as e:\n",
    "    print(f\"[WARN] langgraph 未安装: {e}\")\n",
    "\n",
    "try:\n",
    "    from langfuse import Langfuse\n",
    "    from langfuse.langchain import CallbackHandler\n",
    "    _HAS_LANGFUSE = True\n",
    "    print(\"[OK] langfuse 已安装\")\n",
    "except ImportError as e:\n",
    "    print(f\"[WARN] langfuse 未安装: {e}\")\n",
    "\n",
    "try:\n",
    "    import yaml\n",
    "    _HAS_YAML = True\n",
    "    print(\"[OK] pyyaml 已安装\")\n",
    "except ImportError as e:\n",
    "    print(f\"[WARN] pyyaml 未安装: {e}\")\n",
    "\n",
    "try:\n",
    "    import redis\n",
    "    _HAS_REDIS = True\n",
    "    print(\"[OK] redis 已安装\")\n",
    "except ImportError:\n",
